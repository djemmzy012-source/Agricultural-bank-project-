<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Agricultural Bank | Forgot Password</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&family=DM+Serif+Display&family=IBM+Plex+Mono:wght@400;500;600&display=swap" rel="stylesheet">
  <style>
    :root {
      --green-dark: #0d2818;
      --green-main: #1a5c38;
      --green-light: #2d8a56;
      --green-pale: #e8f5e9;
      --brown-dark: #3e2723;
      --gold: #f9a825;
      --text-dark: #1a1a1a;
      --text-mid: #5a5a5a;
      --text-light: #8a8a8a;
      --bg-light: #f5f0eb;
      --white: #ffffff;
      --radius-sm: 8px;
      --radius-md: 12px;
      --radius-lg: 20px;
    }

    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      font-family: 'DM Sans', sans-serif;
      background: var(--bg-light);
      min-height: 100vh;
      display: flex;
      flex-direction: column;
    }

    .auth-layout {
      display: flex;
      flex: 1;
      min-height: 100vh;
    }

    .auth-left {
      flex: 1;
      background: linear-gradient(135deg, var(--green-dark) 0%, var(--green-main) 60%, var(--brown-dark) 100%);
      display: flex;
      flex-direction: column;
      justify-content: center;
      align-items: center;
      padding: 48px;
      position: relative;
      overflow: hidden;
    }

    .auth-left::before {
      content: '';
      position: absolute;
      inset: 0;
      background: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='0.03'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
      pointer-events: none;
    }

    .auth-left-content {
      position: relative;
      z-index: 1;
      text-align: center;
      max-width: 420px;
    }

    .auth-logo {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 14px;
      margin-bottom: 48px;
    }

    .auth-logo-icon {
      width: 52px;
      height: 52px;
      background: rgba(255,255,255,0.15);
      border-radius: 14px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 24px;
      font-weight: 700;
      color: white;
      font-family: 'DM Serif Display', serif;
    }

    .auth-logo-text {
      text-align: left;
    }

    .auth-logo-name {
      font-family: 'DM Serif Display', serif;
      font-size: 22px;
      color: white;
      display: block;
    }

    .auth-logo-tag {
      font-size: 13px;
      color: rgba(255,255,255,0.6);
      font-weight: 500;
    }

    .auth-left h2 {
      font-family: 'DM Serif Display', serif;
      font-size: 36px;
      color: white;
      line-height: 1.3;
      margin-bottom: 20px;
    }

    .auth-left p {
      font-size: 16px;
      color: rgba(255,255,255,0.75);
      line-height: 1.7;
    }

    .auth-right {
      flex: 1;
      display: flex;
      flex-direction: column;
      justify-content: center;
      align-items: center;
      padding: 48px;
      background: var(--white);
    }

    .auth-form-wrapper {
      width: 100%;
      max-width: 420px;
    }

    .auth-form-wrapper h1 {
      font-family: 'DM Serif Display', serif;
      font-size: 32px;
      color: var(--text-dark);
      margin-bottom: 8px;
    }

    .auth-form-wrapper .subtitle {
      font-size: 15px;
      color: var(--text-mid);
      margin-bottom: 36px;
      line-height: 1.6;
    }

    .form-group {
      margin-bottom: 20px;
    }

    .form-group label {
      display: block;
      font-size: 13px;
      font-weight: 600;
      color: var(--text-dark);
      margin-bottom: 6px;
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }

    .form-group input {
      width: 100%;
      padding: 14px 16px;
      border: 2px solid #e0dcd7;
      border-radius: var(--radius-sm);
      font-size: 15px;
      font-family: 'DM Sans', sans-serif;
      transition: border-color 0.2s, box-shadow 0.2s;
      background: var(--white);
    }

    .form-group input:focus {
      outline: none;
      border-color: var(--green-main);
      box-shadow: 0 0 0 3px rgba(26, 92, 56, 0.1);
    }

    .form-group input::placeholder {
      color: var(--text-light);
    }

    .btn-submit {
      width: 100%;
      padding: 16px;
      background: var(--green-main);
      color: white;
      border: none;
      border-radius: var(--radius-sm);
      font-size: 16px;
      font-weight: 600;
      font-family: 'DM Sans', sans-serif;
      cursor: pointer;
      transition: background 0.2s, transform 0.15s;
      margin-top: 8px;
    }

    .btn-submit:hover {
      background: var(--green-dark);
      transform: translateY(-1px);
    }

    .btn-submit:active {
      transform: translateY(0);
    }

    .error-box {
      background: #fef2f2;
      border: 1px solid #fecaca;
      color: #b91c1c;
      padding: 14px 18px;
      border-radius: var(--radius-sm);
      font-size: 14px;
      margin-bottom: 24px;
      line-height: 1.5;
    }

    .success-box {
      background: #f0fdf4;
      border: 1px solid #bbf7d0;
      color: #166534;
      padding: 14px 18px;
      border-radius: var(--radius-sm);
      font-size: 14px;
      margin-bottom: 24px;
      line-height: 1.5;
    }

    .info-box {
      background: #fffbeb;
      border: 1px solid #fde68a;
      color: #92400e;
      padding: 14px 18px;
      border-radius: var(--radius-sm);
      font-size: 14px;
      margin-bottom: 24px;
      line-height: 1.5;
      font-family: 'IBM Plex Mono', monospace;
    }

    .info-box strong {
      display: block;
      margin-bottom: 4px;
      font-family: 'DM Sans', sans-serif;
    }

    .auth-divider {
      display: flex;
      align-items: center;
      gap: 16px;
      margin: 28px 0;
      color: var(--text-light);
      font-size: 13px;
    }

    .auth-divider::before,
    .auth-divider::after {
      content: '';
      flex: 1;
      height: 1px;
      background: #e0dcd7;
    }

    .auth-links {
      text-align: center;
      margin-top: 28px;
    }

    .auth-links a {
      color: var(--green-main);
      text-decoration: none;
      font-weight: 500;
      font-size: 14px;
      transition: color 0.2s;
    }

    .auth-links a:hover {
      color: var(--green-dark);
      text-decoration: underline;
    }

    .auth-links span {
      color: var(--text-light);
      margin: 0 8px;
    }

    .key-icon {
      font-size: 48px;
      margin-bottom: 20px;
      display: block;
    }

    @media (max-width: 768px) {
      .auth-left {
        display: none;
      }

      .auth-right {
        padding: 32px 24px;
      }
    }
  </style>
</head>
<body>
  <div class="auth-layout">
    <!-- Left Panel -->
    <div class="auth-left">
      <div class="auth-left-content">
        <div class="auth-logo">
          <div class="auth-logo-icon">AB</div>
          <div class="auth-logo-text">
            <span class="auth-logo-name">Agricultural Bank</span>
            <span class="auth-logo-tag">AgricBank</span>
          </div>
        </div>
        <span class="key-icon">🔐</span>
        <h2>Let's Get You Back In</h2>
        <p>Enter your username and email address associated with your account, and we'll help you reset your password securely.</p>
      </div>
    </div>

    <!-- Right Panel -->
    <div class="auth-right">
      <div class="auth-form-wrapper">
        <h1>Forgot Password</h1>
        <p class="subtitle">Enter your account details to receive a password reset link.</p>

        <% if (error) { %>
          <div class="error-box"><%= error %></div>
        <% } %>

        <% if (success) { %>
          <div class="success-box"><%= success %></div>
        <% } %>

        <% if (info) { %>
          <div class="info-box">
            <strong>Demo Info:</strong>
            <%= info %>
          </div>
        <% } %>

        <form method="POST" action="/forgot-password">
          <div class="form-group">
            <label for="username">Username</label>
            <input type="text" id="username" name="username" placeholder="Enter your username" required>
          </div>

          <div class="form-group">
            <label for="email">Email Address</label>
            <input type="email" id="email" name="email" placeholder="Enter your email address" required>
          </div>

          <button type="submit" class="btn-submit">Reset Password</button>
        </form>

        <div class="auth-links">
          <a href="/login">Back to Sign In</a>
          <span>·</span>
          <a href="/register">Open an Account</a>
        </div>
      </div>
    </div>
  </div>
</body>
</html>