  <!-- ==========================================
       SCRIPTS
       ========================================== -->
  <script>
    // Scroll Spy for TOC sidebar
    document.addEventListener('DOMContentLoaded', () => {
      const tocLinks = document.querySelectorAll('.toc-list a');
      const sections = document.querySelectorAll('.sec-section[id]');
      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            tocLinks.forEach(l => l.classList.remove('active'));
            const activeLink = document.querySelector('.toc-list a[href="#' + entry.target.id + '"]');
            if (activeLink) activeLink.classList.add('active');
          }
        });
      }, { rootMargin: '-15% 0px -70% 0px' });
      sections.forEach(sec => observer.observe(sec));
    });

    // Toggle checklist items (click to mark done/undone)
    function toggleCheck(li) {
      li.classList.toggle('done');
      const checkItem = li.querySelector('.check-item');
      checkItem.textContent = li.classList.contains('done') ? '✓' : '';
    }

    // Show info modal/alert for cards
    function showInfo(type) {
      let msg = "";
      switch(type) {
        case 'sms': msg = "To enable SMS verification, go to Dashboard → Profile → Security Settings."; break;
        case 'authenticator': msg = "We recommend authenticator apps for stronger security. Go to Dashboard → Profile → MFA Settings to set up Google Authenticator or Authy."; break;
        case 'biometric': msg = "Biometric login requires iOS Face ID or Android fingerprint configured at the device level."; break;
        case 'hardware': msg = "Hardware tokens can be requested through your branch manager. Contact us at 1-800-555-AGRI to order a YubiKey."; break;
      }
      alert(msg);
    }

    // Password strength tester (local only — nothing leaves browser)
    function testStrength() {
      const pw = document.getElementById('pwInput').value;
      const bar = document.getElementById('strengthBar');
      const label = document.getElementById('strengthLabel');

      if (!pw) {
        bar.className = 'strength-bar';
        label.textContent = 'Enter a password to check strength';
        label.style.color = 'var(--text-secondary)';
        return;
      }

      let score = 0;
      if (pw.length >= 8) score++;
      if (pw.length >= 12) score++;
      if (/[A-Z]/.test(pw)) score++;
      if (/[a-z]/.test(pw)) score++;
      if (/[0-9]/.test(pw)) score++;
      if (/[^A-Za-z0-9]/.test(pw)) score++;
      if (/^.*\d.*\d.*\d.*$/.test(pw)) score++;
      if (pw.length >= 16) score++;

      // Penalize weak patterns
      ['password','123456','qwerty','abc123','letmein','welcome'].forEach(pattern => {
        if (pw.toLowerCase().includes(pattern)) score -= 2;
      });

      bar.className = 'strength-bar';
      if (score <= 2) { bar.classList.add('weak'); label.textContent = 'Weak — easily guessable'; label.style.color = 'var(--danger)'; }
      else if (score <= 4) { bar.classList.add('fair'); label.textContent = 'Fair — could be stronger'; label.style.color = 'var(--warning)'; }
      else if (score <= 6) { bar.classList.add('good'); label.textContent = 'Good — decent protection'; label.style.color = 'var(--info)'; }
      else { bar.classList.add('strong'); label.textContent = 'Strong — excellent! 🛡️'; label.style.color = 'var(--success)'; }
    }

    // Live Chat widget
    function toggleChat() {
      document.getElementById('chatWindow').classList.toggle('hidden');
    }
    function handleChatEnter(e) { if (e.key === 'Enter') sendChatMessage(); }
    function sendChatMessage() {
      const input = document.getElementById('chat-input');
      const text = input.value.trim();
      if (!text) return;
      
      // Create elements safely to avoid XSS and syntax issues
      const userDiv = document.createElement('div');
      userDiv.className = 'message user';
      const userBubble = document.createElement('div');
      userBubble.className = 'message-bubble';
      userBubble.textContent = text; // TextContent prevents XSS and parsing errors
      userDiv.appendChild(userBubble);
      
      const body = document.getElementById('chatBody');
      body.appendChild(userDiv);
      input.value = '';
      body.scrollTop = body.scrollHeight;
      
      setTimeout(() => {
        const responses = [
          "Thanks for reaching out! Let me look into that for you right away. 🛡️",
          "I'd be happy to help with that. Could you provide a bit more detail?",
          "For urgent security concerns, please call our 24/7 Fraud Hotline: 1-800-555-FRAUD.",
          "You can also manage your security settings directly at Dashboard → Profile → Security Settings.",
          "Great question! One moment while I pull up the information for you. 🌾"
        ];
        
        const botDiv = document.createElement('div');
        botDiv.className = 'message bot';
        const botBubble = document.createElement('div');
        botBubble.className = 'message-bubble';
        botBubble.textContent = responses[Math.floor(Math.random() * responses.length)];
        botDiv.appendChild(botBubble);
        
        body.appendChild(botDiv);
        body.scrollTop = body.scrollHeight;
      }, 800);
    }

    // Placeholder for article opening
    function openArticle(id) { alert('Opening detailed article: ' + id + '\n\n(This would navigate to a knowledge base page.)'); }
  </script>

