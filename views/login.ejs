<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sign In | AgriBank Texas</title>
    <link href="https://fonts.googleapis.com/css2?family=Merriweather:wght@400;700;900&family=Open+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: 'Open Sans', sans-serif; background: #f5f1e8; min-height: 100vh; }
        .auth-page { min-height: 100vh; display: flex; }
        .auth-wrapper { display: flex; width: 100%; min-height: 100vh; }
        .auth-brand { flex: 1; background: linear-gradient(145deg, #2D5A27 0%, #1E3D1A 50%, #2C2416 100%); display: flex; align-items: center; justify-content: center; padding: 60px; position: relative; overflow: hidden; }
        .brand-content { max-width: 440px; color: white; position: relative; z-index: 1; }
        .brand-logo { display: flex; align-items: center; gap: 16px; margin-bottom: 48px; }
        .brand-logo-icon { width: 64px; height: 64px; background: #C4A35A; border-radius: 12px; display: flex; align-items: center; justify-content: center; font-size: 36px; }
        .brand-logo-name { font-family: 'Merriweather', serif; font-size: 28px; font-weight: 900; }
        .brand-logo-tagline { font-size: 11px; color: #D4BC7E; letter-spacing: 2px; text-transform: uppercase; }
        .brand-content h1 { font-size: 40px; font-weight: 900; margin-bottom: 16px; }
        .brand-content > p { font-size: 18px; opacity: 0.85; margin-bottom: 40px; }
        .brand-features { display: flex; flex-direction: column; gap: 20px; }
        .brand-feature { display: flex; align-items: center; gap: 16px; font-size: 16px; }
        .brand-feature-icon { width: 32px; height: 32px; background: rgba(255,255,255,0.15); border-radius: 50%; display: flex; align-items: center; justify-content: center; }
        .auth-form-section { flex: 1; display: flex; align-items: center; justify-content: center; padding: 60px; background: white; }
        .auth-form-container { width: 100%; max-width: 420px; }
        .auth-form-container h2 { font-family: 'Merriweather', serif; font-size: 32px; margin-bottom: 8px; color: #2C2416; }
        .auth-subtitle { color: #5C5C5C; font-size: 16px; margin-bottom: 32px; }
        .alert { padding: 16px 20px; border-radius: 8px; margin-bottom: 20px; background: #FDF2F2; color: #A63D40; border: 1px solid rgba(166,61,64,0.2); }
        .success-alert { background: #F0FDF4; color: #166534; border: 1px solid rgba(22,101,52,0.2); }
        .form-group { margin-bottom: 24px; }
        .form-label { display: block; font-size: 13px; font-weight: 600; color: #5C5C5C; margin-bottom: 8px; text-transform: uppercase; }
        .form-input { width: 100%; padding: 14px 16px; border: 1px solid #E5E0D8; border-radius: 8px; font-size: 15px; font-family: 'Open Sans', sans-serif; }
        .form-input:focus { outline: none; border-color: #2D5A27; box-shadow: 0 0 0 3px rgba(45,90,39,0.1); }
        .form-remember { display: flex; justify-content: space-between; align-items: center; margin-bottom: 24px; }
        .checkbox-wrapper { display: flex; align-items: center; gap: 8px; font-size: 14px; color: #5C5C5C; }
        .forgot-link { font-size: 14px; color: #2D5A27; font-weight: 600; text-decoration: none; }
        .forgot-link:hover { text-decoration: underline; }
        .btn { display: inline-flex; align-items: center; justify-content: center; padding: 16px 32px; border-radius: 8px; font-family: 'Open Sans', sans-serif; font-size: 16px; font-weight: 600; cursor: pointer; border: none; }
        .btn-primary { background: #2D5A27; color: white; width: 100%; }
        .btn-primary:hover { background: #4A7C42; }
        .auth-footer { text-align: center; font-size: 14px; color: #5C5C5C; margin-top: 24px; }
        .auth-footer a { color: #2D5A27; font-weight: 600; text-decoration: none; }
        .auth-footer a:hover { text-decoration: underline; }

        /* 📱 MOBILE RESPONSIVE FIXES */
        @media (max-width: 900px) {
            .auth-wrapper { flex-direction: column; }
            .auth-brand { padding: 40px 24px; min-height: auto; }
            .brand-content { text-align: center; }
            .brand-logo { justify-content: center; }
            .brand-content h1 { font-size: 32px; }
            .brand-features { align-items: center; }
            .auth-form-section { padding: 40px 24px; }
            .auth-form-container { max-width: 100%; }
        }
        @media (max-width: 480px) {
            .auth-brand { padding: 32px 16px; }
            .brand-logo-icon { width: 48px; height: 48px; font-size: 28px; }
            .brand-logo-name { font-size: 22px; }
            .brand-content h1 { font-size: 26px; }
            .brand-content > p { font-size: 15px; }
            .auth-form-section { padding: 32px 16px; }
            .auth-form-container h2 { font-size: 26px; }
            .form-input { padding: 12px 14px; font-size: 14px; }
            .btn { padding: 14px 24px; font-size: 15px; }
            .form-remember { flex-direction: column; align-items: flex-start; gap: 12px; }
        }
    </style>
</head>
<body>
    <div class="auth-page">
        <div class="auth-wrapper">
            <div class="auth-brand">
                <div class="brand-content">
                    <div class="brand-logo">
                        <div class="brand-logo-icon">🌾</div>
                        <div>
                            <div class="brand-logo-name">AgriBank</div>
                            <div class="brand-logo-tagline">Texas</div>
                        </div>
                    </div>
                    <h1>Rooted in Texas Soil Since 1923</h1>
                    <p>Community banking for farmers, ranchers, and families across the Lone Star State.</p>
                    <div class="brand-features">
                        <div class="brand-feature"><span class="brand-feature-icon">✓</span><span>FDIC Insured up to $250,000</span></div>
                        <div class="brand-feature"><span class="brand-feature-icon">✓</span><span>Free Online & Mobile Banking</span></div>
                        <div class="brand-feature"><span class="brand-feature-icon">✓</span><span>Agricultural Loans & Lines of Credit</span></div>
                    </div>
                </div>
            </div>
            <div class="auth-form-section">
                <div class="auth-form-container">
                    <h2>Welcome Back</h2>
                    <p class="auth-subtitle">Sign in to access your accounts</p>
                    <% if (error) { %>
                    <div class="alert"><%= error %></div>
                    <% } %>
                    <% if (success) { %>
                    <div class="alert success-alert"><%= success %></div>
                    <% } %>
                    <form action="/login" method="POST">
                        <div class="form-group">
                            <label class="form-label">Username</label>
                            <input type="text" name="username" class="form-input" placeholder="Enter your username" required>
                        </div>
                        <div class="form-group">
                            <label class="form-label">Password</label>
                            <input type="password" name="password" class="form-input" placeholder="Enter your password" required>
                        </div>
                        <div class="form-remember">
                            <label class="checkbox-wrapper"><input type="checkbox"> Remember me</label>
                            <a href="/forgot-password" class="forgot-link">Forgot password?</a>
                        </div>
                        <button type="submit" class="btn btn-primary">Sign In</button>
                    </form>
                    <p class="auth-footer">Don't have an account? <a href="/register">Open an Account</a></p>
                </div>
            </div>
        </div>
    </div>
</body>
</html>