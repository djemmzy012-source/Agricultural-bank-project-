<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('partials/head', { title: 'Loan Services | AgriBank Texas' }) %>
  <style>
    :root {
      --navy: #0a1c14; --green-900: #0f2b1f; --green-800: #144a25;
      --green-700: #1a5c30; --green-600: #22753d; --gold: #d4a047;
      --bg: #f0f2f5; --surface: #ffffff; --text: #0f172a;
      --text-secondary: #64748b; --border: #e2e8f0;
      --success: #10b981; --danger: #ef4444; --warning: #f59e0b;
      --sidebar-w: 260px; --header-h: 72px; --radius: 16px; --radius-sm: 10px;
      --shadow: 0 1px 3px rgba(0,0,0,0.06), 0 4px 12px rgba(0,0,0,0.04);
      --shadow-lg: 0 8px 30px rgba(0,0,0,0.08);
    }
    * { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }
    body { font-family: 'DM Sans', -apple-system, sans-serif; background: var(--bg); color: var(--text); line-height: 1.5; -webkit-font-smoothing: antialiased; }
    a { text-decoration: none; color: inherit; transition: 0.2s; }

    /* SIDEBAR */
    .sidebar { position: fixed; top: 0; left: 0; width: var(--sidebar-w); height: 100vh; background: var(--green-900); color: white; z-index: 100; display: flex; flex-direction: column; transition: transform 0.3s ease; overflow-y: auto; }
    .sidebar-brand { padding: 1.75rem 1.5rem; border-bottom: 1px solid rgba(255,255,255,0.08); }
    .sidebar-brand h2 { font-family: 'DM Serif Display', serif; font-size: 1.35rem; }
    .sidebar-brand span { color: var(--gold); }
    .sidebar-brand .sub { font-size: 0.65rem; text-transform: uppercase; letter-spacing: 1.5px; opacity: 0.5; margin-top: 0.25rem; font-weight: 600; }
    .sidebar-nav { padding: 1.25rem 1rem; flex: 1; }
    .nav-section { font-size: 0.6rem; text-transform: uppercase; letter-spacing: 1.5px; opacity: 0.35; padding: 0.75rem 0.75rem 0.4rem; font-weight: 700; }
    .nav-item { display: flex; align-items: center; gap: 0.75rem; padding: 0.7rem 0.85rem; border-radius: var(--radius-sm); font-size: 0.875rem; font-weight: 500; color: rgba(255,255,255,0.65); margin-bottom: 2px; cursor: pointer; }
    .nav-item:hover { background: rgba(255,255,255,0.08); color: white; }
    .nav-item.active { background: rgba(212, 160, 71, 0.15); color: var(--gold); font-weight: 600; }
    .nav-item .icon { width: 20px; text-align: center; font-size: 1rem; opacity: 0.85; }
    .sidebar-footer { padding: 1.25rem; border-top: 1px solid rgba(255,255,255,0.08); }
    .sidebar-user { display: flex; align-items: center; gap: 0.75rem; padding: 0.5rem; border-radius: var(--radius-sm); cursor: pointer; }
    .sidebar-user:hover { background: rgba(255,255,255,0.05); }
    .avatar { width: 36px; height: 36px; border-radius: 50%; background: var(--gold); display: flex; align-items: center; justify-content: center; font-weight: 700; font-size: 0.85rem; color: var(--green-900); }
    .user-info .name { font-size: 0.85rem; font-weight: 600; }
    .user-info .role { font-size: 0.7rem; opacity: 0.5; }

    /* MAIN */
    .main { margin-left: var(--sidebar-w); min-height: 100vh; }
    .topbar { position: sticky; top: 0; height: var(--header-h); background: rgba(255,255,255,0.85); backdrop-filter: blur(20px); border-bottom: 1px solid var(--border); display: flex; align-items: center; justify-content: space-between; padding: 0 2rem; z-index: 50; }
    .topbar-left { display: flex; align-items: center; gap: 1rem; }
    .hamburger { display: none; background: none; border: none; font-size: 1.5rem; cursor: pointer; color: var(--text); }
    .topbar-title h1 { font-size: 1.15rem; font-weight: 700; }
    .topbar-right { display: flex; align-items: center; gap: 0.75rem; }
    .topbar-btn { width: 40px; height: 40px; border-radius: 50%; background: transparent; border: 1px solid var(--border); display: flex; align-items: center; justify-content: center; font-size: 1.1rem; cursor: pointer; transition: 0.2s; }
    .topbar-btn:hover { background: #f8fafc; border-color: #cbd5e1; }
    .content { padding: 2rem; max-width: 1400px; margin: 0 auto; }

    /* LOANS LAYOUT */
    .loans-grid { display: grid; grid-template-columns: 1fr 360px; gap: 2rem; }
    
    /* PRODUCT CARDS */
    .products-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 1.5rem; }
    .product-card {
      background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius);
      padding: 2rem; transition: all 0.3s; position: relative; overflow: hidden;
    }
    .product-card:hover { transform: translateY(-5px); box-shadow: var(--shadow-lg); border-color: var(--gold); }
    .product-card::before { content: ''; position: absolute; top: 0; left: 0; width: 4px; height: 100%; background: var(--green-600); }
    .product-card:nth-child(2)::before { background: var(--warning); }
    .product-card:nth-child(3)::before { background: #8b5cf6; }

    .prod-icon { width: 56px; height: 56px; background: #f0fdf4; border-radius: 14px; display: flex; align-items: center; justify-content: center; font-size: 1.8rem; margin-bottom: 1.25rem; }
    .product-card:nth-child(2) .prod-icon { background: #fefce8; }
    .product-card:nth-child(3) .prod-icon { background: #f5f3ff; }

    .prod-title { font-size: 1.1rem; font-weight: 800; margin-bottom: 0.25rem; color: var(--text); }
    .prod-rate { font-size: 0.85rem; font-weight: 700; color: var(--success); margin-bottom: 1rem; display: inline-block; background: #ecfdf5; padding: 0.2rem 0.5rem; border-radius: 4px; }
    .prod-desc { font-size: 0.9rem; color: var(--text-secondary); line-height: 1.6; margin-bottom: 1.5rem; }
    .prod-features { list-style: none; margin-bottom: 1.5rem; }
    .prod-features li { font-size: 0.8rem; color: var(--text-secondary); margin-bottom: 0.5rem; display: flex; align-items: center; gap: 0.5rem; }
    .prod-features li::before { content: '✓'; color: var(--success); font-weight: 700; }

    .btn-apply { width: 100%; padding: 0.75rem; background: var(--green-800); color: white; border: none; border-radius: 8px; font-weight: 600; cursor: pointer; transition: 0.2s; }
    .btn-apply:hover { background: var(--green-700); }

    /* CALCULATOR SIDEBAR */
    .calc-widget { background: var(--surface); border-radius: var(--radius); padding: 1.5rem; box-shadow: var(--shadow); border: 1px solid var(--border); position: sticky; top: calc(var(--header-h) + 1.5rem); }
    .calc-widget h3 { font-size: 1rem; font-weight: 700; margin-bottom: 1.25rem; }
    .calc-group { margin-bottom: 1rem; }
    .calc-group label { display: block; font-size: 0.75rem; font-weight: 600; color: var(--text-secondary); margin-bottom: 0.4rem; }
    .calc-input { width: 100%; padding: 0.6rem; border: 1px solid var(--border); border-radius: 6px; font-size: 0.9rem; }
    .calc-result { background: #f8fafc; padding: 1rem; border-radius: 8px; margin-top: 1rem; text-align: center; border: 1px solid var(--border); }
    .calc-val { font-size: 1.75rem; font-weight: 800; font-family: 'DM Serif Display', serif; color: var(--green-700); }
    .calc-label { font-size: 0.75rem; color: var(--text-secondary); }

    .btn-text { font-size: 0.75rem; font-weight: 600; color: var(--green-700); display: inline-flex; align-items: center; gap: 0.25rem; cursor: pointer; margin-bottom: 1rem; }
    .btn-text:hover { color: var(--green-900); }

    /* MOBILE */
    .sidebar-overlay { display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.5); z-index: 99; opacity: 0; transition: opacity 0.3s; }
    .sidebar-overlay.show { display: block; opacity: 1; }
    .mobile-nav { display: none; position: fixed; bottom: 0; left: 0; right: 0; background: white; border-top: 1px solid var(--border); z-index: 100; padding: 0.5rem 0; padding-bottom: max(0.5rem, env(safe-area-inset-bottom)); box-shadow: 0 -4px 20px rgba(0,0,0,0.06); }
    .mobile-nav-grid { display: grid; grid-template-columns: repeat(5, 1fr); }
    .mob-nav-item { display: flex; flex-direction: column; align-items: center; gap: 0.2rem; padding: 0.5rem 0; font-size: 0.6rem; font-weight: 600; color: var(--text-secondary); cursor: pointer; }
    .mob-nav-item.active { color: var(--green-700); }
    .mob-nav-item .mob-icon { font-size: 1.25rem; }

    @media (max-width: 1024px) {
      .loans-grid { grid-template-columns: 1fr; }
      .calc-widget { position: static; margin-top: 1rem; }
    }
    @media (max-width: 900px) {
      .sidebar { transform: translateX(-100%); }
      .sidebar.open { transform: translateX(0); }
      .main { margin-left: 0; }
      .hamburger { display: flex; }
      .content { padding: 1.25rem; padding-bottom: 5rem; }
      .topbar { padding: 0 1.25rem; }
      .mobile-nav { display: block; }
    }
    @keyframes fadeInUp { from { opacity: 0; transform: translateY(12px); } to { opacity: 1; transform: translateY(0); } }
    .animate { animation: fadeInUp 0.4s ease both; }
  </style>
</head>
<body>
  <%
    /* 
       FIX: Added strict checks for 'user' and 'products' variables.
       This prevents the "ReferenceError: user is not defined" (500 Error).
    */
    const safeUser = (typeof user !== 'undefined' && user) ? user : { firstName: 'Customer', lastName: '' };
    const initials = ((safeUser.firstName || 'C')[0] + (safeUser.lastName || 'U')[0]).toUpperCase();
    const isAdmin = safeUser.isAdmin === 1;
    
    const loanProducts = (typeof products !== 'undefined' && Array.isArray(products)) ? products : [
      { title: 'Operating Loan', rate: '6.25% APR', desc: 'Flexible financing for seed, feed, labor, and seasonal cash flow.' },
      { title: 'Equipment Loan', rate: '5.90% APR', desc: 'Finance tractors, combines, irrigation systems, and processing equipment.' },
      { title: 'Land Improvement Loan', rate: '6.75% APR', desc: 'Support fencing, barns, drainage, and infrastructure upgrades.' }
    ];
  %>

  <div class="sidebar-overlay" id="sidebarOverlay" onclick="toggleSidebar()"></div>
  <aside class="sidebar" id="sidebar">
    <div class="sidebar-brand"><h2>Agri<span>Bank</span></h2><div class="sub">Texas Regional</div></div>
    <nav class="sidebar-nav">
      <div class="nav-section">Main</div>
      <a href="/dashboard" class="nav-item"><span class="icon">📊</span> Dashboard</a>
      <a href="/accounts" class="nav-item"><span class="icon">💳</span> Accounts</a>
      <a href="/transactions" class="nav-item"><span class="icon">📋</span> Transactions</a>
      <a href="/transfer" class="nav-item"><span class="icon">⇄</span> Transfer</a>
      <div class="nav-section">Services</div>
      <a href="/billpay" class="nav-item"><span class="icon">💸</span> Bill Pay</a>
      <a href="/deposits" class="nav-item"><span class="icon">📱</span> Deposits</a>
      <a href="/loans" class="nav-item active"><span class="icon">🏦</span> Loans</a>
      <div class="nav-section">Account</div>
      <a href="/profile" class="nav-item"><span class="icon">👤</span> Profile</a>
      <a href="/notifications" class="nav-item"><span class="icon">🔔</span> Notifications</a>
      <% if(isAdmin) { %><a href="/admin" class="nav-item"><span class="icon">⚙️</span> Admin</a><% } %>
    </nav>
    <div class="sidebar-footer">
      <a href="/logout" class="sidebar-user">
        <div class="avatar"><%= initials %></div>
        <div class="user-info"><div class="name"><%= safeUser.firstName %></div><div class="role"><%= isAdmin ? 'Administrator' : 'Member' %></div></div>
      </a>
    </div>
  </aside>

  <div class="main">
    <header class="topbar">
      <div class="topbar-left">
        <button class="hamburger" onclick="toggleSidebar()">☰</button>
        <div class="topbar-title"><h1>Loan Services</h1></div>
      </div>
      <div class="topbar-right">
        <a href="/notifications" class="topbar-btn">🔔</a>
        <a href="/profile" class="topbar-btn">👤</a>
      </div>
    </header>

    <div class="content">
      <a href="/dashboard" class="btn-text animate">← Back to Dashboard</a>

      <div class="loans-grid">
        
        <!-- LEFT: PRODUCTS -->
        <div>
          <h2 style="font-size:1.5rem; margin-bottom:0.5rem;" class="animate">Agricultural Financing</h2>
          <p style="color:var(--text-secondary); margin-bottom:1.5rem;" class="animate">Flexible rates and terms designed for the Texas farming cycle.</p>
          
          <div class="products-grid animate">
            <% loanProducts.forEach(p => { 
               const icon = p.title.includes('Equipment') ? '🚜' : (p.title.includes('Operating') ? '🌱' : '🏗️');
               const features = [
                 'Funds available within 24 hours',
                 'No pre-payment penalties',
                 'Dedicated loan officer'
               ];
            %>
              <div class="product-card">
                <div class="prod-icon"><%= icon %></div>
                <div class="prod-title"><%= p.title %></div>
                <div class="prod-rate">Starting at <%= p.rate %></div>
                <p class="prod-desc"><%= p.desc %></p>
                <ul class="prod-features">
                  <% features.forEach(f => { %><li><%= f %></li><% }) %>
                </ul>
                <button class="btn-apply" onclick="alert('Our loan officer will contact you shortly to begin the <%= p.title %> application process.')">
                  Apply for <%= p.title %>
                </button>
              </div>
            <% }) %>
          </div>
        </div>

        <!-- RIGHT: CALCULATOR -->
        <div>
          <div class="calc-widget animate">
            <h3>🧮 Payment Estimator</h3>
            <div class="calc-group">
              <label>Loan Amount ($)</label>
              <input type="number" id="calc-amount" class="calc-input" value="50000" oninput="calculateLoan()">
            </div>
            <div class="calc-group">
              <label>Interest Rate (%)</label>
              <input type="number" id="calc-rate" class="calc-input" value="6.25" step="0.01" oninput="calculateLoan()">
            </div>
            <div class="calc-group">
              <label>Term (Months)</label>
              <input type="number" id="calc-term" class="calc-input" value="60" oninput="calculateLoan()">
            </div>
            
            <div class="calc-result">
              <div class="calc-val" id="calc-monthly">$972.40</div>
              <div class="calc-label">Estimated Monthly Payment</div>
            </div>
            <p style="font-size:0.65rem; color:var(--text-secondary); margin-top:0.75rem; text-align:center;">
              *Estimates only. Final rates based on creditworthiness.
            </p>
          </div>
        </div>

      </div>
    </div>
  </div>

  <nav class="mobile-nav">
    <div class="mobile-nav-grid">
      <a href="/dashboard" class="mob-nav-item"><span class="mob-icon">📊</span>Home</a>
      <a href="/accounts" class="mob-nav-item"><span class="mob-icon">💳</span>Accounts</a>
      <a href="/transfer" class="mob-nav-item"><span class="mob-icon">⇄</span>Transfer</a>
      <a href="/billpay" class="mob-nav-item"><span class="mob-icon">💸</span>Pay</a>
      <a href="/profile" class="mob-nav-item"><span class="mob-icon">👤</span>Profile</a>
    </div>
  </nav>

  <script>
    function toggleSidebar() {
      document.getElementById('sidebar').classList.toggle('open');
      document.getElementById('sidebarOverlay').classList.toggle('show');
    }

    // Simple Loan Calculator Logic
    function calculateLoan() {
      const amount = parseFloat(document.getElementById('calc-amount').value);
      const rate = parseFloat(document.getElementById('calc-rate').value) / 100 / 12;
      const term = parseFloat(document.getElementById('calc-term').value);

      if (amount > 0 && rate > 0 && term > 0) {
        const x = Math.pow(1 + rate, term);
        const monthly = (amount * x * rate) / (x - 1);
        document.getElementById('calc-monthly').textContent = '$' + monthly.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
      } else {
        document.getElementById('calc-monthly').textContent = '—';
      }
    }
  </script>
</body>
</html>

