                        <body>
                            <!DOCTYPE html>
<html lang="en">
<head>
  <%- include('partials/head', { title: 'Transfer Funds | AgriBank Texas' }) %>
  <style>
    /* =========================================
       TRANSFER PAGE STYLES (AgriBank Theme)
       ========================================= */
    :root {
      --navy: #0a1c14; --green-900: #0f2b1f; --green-800: #144a25;
      --green-700: #1a5c30; --green-600: #22753d; --gold: #d4a047;
      --bg: #f0f2f5; --surface: #ffffff; --text: #0f172a;
      --text-secondary: #64748b; --border: #e2e8f0;
      --success: #10b981; --danger: #ef4444;
      --sidebar-w: 260px; --header-h: 72px; --radius: 16px; --radius-sm: 10px;
      --shadow: 0 1px 3px rgba(0,0,0,0.06), 0 4px 12px rgba(0,0,0,0.04);
      --shadow-lg: 0 8px 30px rgba(0,0,0,0.08);
    }
    * { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }
    body { font-family: 'DM Sans', -apple-system, sans-serif; background: var(--bg); color: var(--text); line-height: 1.5; -webkit-font-smoothing: antialiased; }
    a { text-decoration: none; color: inherit; transition: 0.2s; }

    /* --- SIDEBAR --- */
    .sidebar { position: fixed; top: 0; left: 0; width: var(--sidebar-w); height: 100vh; background: var(--green-900); color: white; z-index: 100; display: flex; flex-direction: column; transition: transform 0.3s ease; overflow-y: auto; }
    .sidebar-brand { padding: 1.75rem 1.5rem; border-bottom: 1px solid rgba(255,255,255,0.08); }
    .sidebar-brand h2 { font-family: 'DM Serif Display', serif; font-size: 1.35rem; }
    .sidebar-brand span { color: var(--gold); }
    .sidebar-brand .sub { font-size: 0.65rem; text-transform: uppercase; letter-spacing: 1.5px; opacity: 0.5; margin-top: 0.25rem; font-weight: 600; }
    .sidebar-nav { padding: 1.25rem 1rem; flex: 1; }
    .nav-section { font-size: 0.6rem; text-transform: uppercase; letter-spacing: 1.5px; opacity: 0.35; padding: 0.75rem 0.75rem 0.4rem; font-weight: 700; }
    .nav-item { display: flex; align-items: center; gap: 0.75rem; padding: 0.7rem 0.85rem; border-radius: var(--radius-sm); font-size: 0.875rem; font-weight: 500; color: rgba(255,255,255,0.65); margin-bottom: 2px; cursor: pointer; }
    .nav-item:hover { background: rgba(255,255,255,0.08); color: white; }
    .nav-item.active { background: rgba(212, 160, 71, 0.15); color: var(--gold); font-weight: 600; }
    .nav-item .icon { width: 20px; text-align: center; font-size: 1rem; opacity: 0.85; }
    .sidebar-footer { padding: 1.25rem; border-top: 1px solid rgba(255,255,255,0.08); }
    .sidebar-user { display: flex; align-items: center; gap: 0.75rem; padding: 0.5rem; border-radius: var(--radius-sm); cursor: pointer; }
    .sidebar-user:hover { background: rgba(255,255,255,0.05); }
    .avatar { width: 36px; height: 36px; border-radius: 50%; background: var(--gold); display: flex; align-items: center; justify-content: center; font-weight: 700; font-size: 0.85rem; color: var(--green-900); }
    .user-info .name { font-size: 0.85rem; font-weight: 600; }
    .user-info .role { font-size: 0.7rem; opacity: 0.5; }

    /* --- MAIN AREA --- */
    .main { margin-left: var(--sidebar-w); min-height: 100vh; }
    .topbar { position: sticky; top: 0; height: var(--header-h); background: rgba(255,255,255,0.85); backdrop-filter: blur(20px); border-bottom: 1px solid var(--border); display: flex; align-items: center; justify-content: space-between; padding: 0 2rem; z-index: 50; }
    .topbar-left { display: flex; align-items: center; gap: 1rem; }
    .hamburger { display: none; background: none; border: none; font-size: 1.5rem; cursor: pointer; color: var(--text); }
    .topbar-title h1 { font-size: 1.15rem; font-weight: 700; }
    .topbar-right { display: flex; align-items: center; gap: 0.75rem; }
    .topbar-btn { width: 40px; height: 40px; border-radius: 50%; background: transparent; border: 1px solid var(--border); display: flex; align-items: center; justify-content: center; font-size: 1.1rem; cursor: pointer; transition: 0.2s; }
    .topbar-btn:hover { background: #f8fafc; border-color: #cbd5e1; }
    .content { padding: 2rem; max-width: 1400px; margin: 0 auto; }

    /* --- TRANSFER GRID --- */
    .transfer-grid { display: grid; grid-template-columns: 1fr 360px; gap: 1.5rem; }
    .form-section { display: flex; flex-direction: column; gap: 1rem; }

    /* --- TABS --- */
    .transfer-tabs { display: flex; background: var(--surface); padding: 0.35rem; border-radius: var(--radius-sm); box-shadow: var(--shadow); gap: 0.25rem; }
    .tab-btn {
      flex: 1; padding: 0.75rem; border: none; background: transparent; border-radius: 8px;
      font-size: 0.8rem; font-weight: 600; cursor: pointer; color: var(--text-secondary);
      transition: all 0.25s; text-align: center;
    }
    .tab-btn.active { background: var(--green-800); color: white; box-shadow: 0 2px 6px rgba(0,0,0,0.1); }
    .tab-btn:hover:not(.active) { background: #f8fafc; }

    /* --- FORMS --- */
    .form-card { background: var(--surface); border-radius: var(--radius); padding: 1.5rem; box-shadow: var(--shadow); border: 1px solid var(--border); }
    .form-card h3 { font-size: 1rem; font-weight: 700; margin-bottom: 1.25rem; padding-bottom: 0.75rem; border-bottom: 1px solid var(--border); }
    .form-group { margin-bottom: 1.25rem; }
    .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
    .form-label { display: block; font-size: 0.7rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px; color: var(--text-secondary); margin-bottom: 0.5rem; }
    .form-input, .form-select {
      width: 100%; padding: 0.7rem 0.9rem; border: 1px solid var(--border); border-radius: 8px;
      font-size: 0.9rem; font-family: inherit; transition: 0.2s; background: white;
    }
    .form-input:focus, .form-select:focus { outline: none; border-color: var(--green-600); box-shadow: 0 0 0 3px rgba(34,117,61,0.1); }
    
    .btn-submit {
      width: 100%; padding: 0.85rem; background: var(--green-800); color: white; border: none;
      border-radius: 8px; font-size: 0.95rem; font-weight: 700; cursor: pointer; transition: 0.2s;
      margin-top: 0.5rem;
    }
    .btn-submit:hover { background: var(--green-700); }
    
    .alert { padding: 1rem 1.25rem; border-radius: 10px; font-size: 0.85rem; margin-bottom: 1rem; display: flex; align-items: center; gap: 0.75rem; }
    .alert-error { background: #fef2f2; color: #991b1b; border: 1px solid #fecaca; }

    /* --- SUMMARY SIDEBAR --- */
    .summary-card { background: var(--surface); border-radius: var(--radius); padding: 1.25rem; box-shadow: var(--shadow); border: 1px solid var(--border); position: sticky; top: calc(var(--header-h) + 1.5rem); }
    .summary-card h4 { font-size: 0.8rem; font-weight: 700; margin-bottom: 0.75rem; padding-bottom: 0.5rem; border-bottom: 1px solid var(--border); }
    .quick-acct { display: flex; align-items: center; gap: 0.75rem; padding: 0.6rem; border-radius: 8px; margin-bottom: 0.5rem; transition: 0.2s; cursor: pointer; border: 1px solid transparent; }
    .quick-acct:hover { background: #f8fafc; border-color: var(--border); }
    .quick-acct-icon { width: 36px; height: 36px; background: #f0fdf4; border-radius: 8px; display: flex; align-items: center; justify-content: center; font-size: 1rem; }
    .quick-acct-info { flex: 1; }
    .quick-acct-name { font-size: 0.85rem; font-weight: 600; }
    .quick-acct-num { font-size: 0.65rem; color: var(--text-secondary); font-family: 'JetBrains Mono', monospace; }
    .quick-acct-bal { font-size: 0.9rem; font-weight: 800; font-family: 'DM Serif Display', serif; }
    .summary-row { display: flex; justify-content: space-between; padding: 0.5rem 0; font-size: 0.8rem; }
    .summary-row .label { color: var(--text-secondary); }
    .summary-row .value { font-weight: 600; }

    .hidden { display: none; }
    .btn-text { font-size: 0.75rem; font-weight: 600; color: var(--green-700); display: inline-flex; align-items: center; gap: 0.25rem; cursor: pointer; margin-bottom: 1rem; }
    .btn-text:hover { color: var(--green-900); }
    @keyframes fadeInUp { from { opacity: 0; transform: translateY(12px); } to { opacity: 1; transform: translateY(0); } }
    .animate { animation: fadeInUp 0.4s ease both; }

    /* --- MOBILE --- */
    .sidebar-overlay { display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.5); z-index: 99; opacity: 0; transition: opacity 0.3s; }
    .sidebar-overlay.show { display: block; opacity: 1; }
    .mobile-nav { display: none; position: fixed; bottom: 0; left: 0; right: 0; background: white; border-top: 1px solid var(--border); z-index: 100; padding: 0.5rem 0; padding-bottom: max(0.5rem, env(safe-area-inset-bottom)); box-shadow: 0 -4px 20px rgba(0,0,0,0.06); }
    .mobile-nav-grid { display: grid; grid-template-columns: repeat(5, 1fr); }
    .mob-nav-item { display: flex; flex-direction: column; align-items: center; gap: 0.2rem; padding: 0.5rem 0; font-size: 0.6rem; font-weight: 600; color: var(--text-secondary); cursor: pointer; }
    .mob-nav-item.active { color: var(--green-700); }
    .mob-nav-item .mob-icon { font-size: 1.25rem; }

    @media (max-width: 1024px) { .transfer-grid { grid-template-columns: 1fr; } .summary-card { position: static; order: -1; } }
    @media (max-width: 900px) {
      .sidebar { transform: translateX(-100%); } .sidebar.open { transform: translateX(0); }
      .main { margin-left: 0; } .hamburger { display: flex; }
      .content { padding: 1.25rem; padding-bottom: 5rem; } .topbar { padding: 0 1.25rem; }
      .mobile-nav { display: block; }
    }
  </style>
</head>
<body>
  <%
    /* 
       🔴 FIX: Safe Variable Initialization 
       We define 'acctList' safely so the page never crashes if 'accounts' is missing.
    */
    var safeUser = user || { firstName: 'Customer' };
    var acctList = (typeof accounts !== 'undefined' && Array.isArray(accounts)) ? accounts : [];
  %>

  <div class="sidebar-overlay" id="sidebarOverlay" onclick="toggleSidebar()"></div>
  <aside class="sidebar" id="sidebar">
    <div class="sidebar-brand"><h2>Agri<span>Bank</span></h2><div class="sub">Texas Regional</div></div>
    <nav class="sidebar-nav">
      <div class="nav-section">Main</div>
      <a href="/dashboard" class="nav-item"><span class="icon">📊</span> Dashboard</a>
      <a href="/accounts" class="nav-item"><span class="icon">💳</span> Accounts</a>
      <a href="/transactions" class="nav-item"><span class="icon">📋</span> Transactions</a>
      <a href="/transfer" class="nav-item active"><span class="icon">⇄</span> Transfer</a>
      <div class="nav-section">Services</div>
      <a href="/billpay" class="nav-item"><span class="icon">💸</span> Bill Pay</a>
      <a href="/deposits" class="nav-item"><span class="icon">📱</span> Deposits</a>
      <a href="/loans" class="nav-item"><span class="icon">🏦</span> Loans</a>
      <div class="nav-section">Account</div>
      <a href="/profile" class="nav-item"><span class="icon">👤</span> Profile</a>
      <a href="/notifications" class="nav-item"><span class="icon">🔔</span> Notifications</a>
    </nav>
    <div class="sidebar-footer">
      <a href="/logout" class="sidebar-user">
        <div class="avatar"><%= safeUser.firstName.charAt(0).toUpperCase() %></div>
        <div class="user-info"><div class="name"><%= safeUser.firstName %></div><div class="role">Member</div></div>
      </a>
    </div>
  </aside>

  <div class="main">
    <header class="topbar">
      <div class="topbar-left">
        <button class="hamburger" onclick="toggleSidebar()">☰</button>
        <div class="topbar-title"><h1>Transfer Funds</h1></div>
      </div>
      <div class="topbar-right">
        <a href="/notifications" class="topbar-btn">🔔</a>
        <a href="/profile" class="topbar-btn">👤</a>
      </div>
    </header>

    <div class="content">
      <div style="margin-bottom: 1.25rem;"><a href="/dashboard" class="btn-text animate">← Back to Dashboard</a></div>
      
      <% if (typeof error !== 'undefined' && error) { %>
        <div class="alert alert-error animate">⚠️ <%= error %></div>
      <% } %>

      <div class="transfer-grid">
        <div class="form-section animate">
          <!-- TABS -->
          <div class="transfer-tabs">
            <button class="tab-btn active" onclick="showForm('internal', this)">Internal</button>
            <button class="tab-btn" onclick="showForm('domestic', this)">Domestic Wire</button>
            <button class="tab-btn" onclick="showForm('international', this)">International</button>
          </div>

          <!-- 1. INTERNAL TRANSFER FORM -->
          <form id="form-internal" class="form-card" action="/transfer" method="POST">
            <input type="hidden" name="transferType" value="internal">
            <h3>Between Your Accounts</h3>
            
            <div class="form-group">
              <label class="form-label">From Account</label>
              <select name="fromAccount" class="form-select" required>
                <option value="">Select source</option>
                <% acctList.forEach(function(acc) { %>
                  <option value="<%= acc.id %>"><%= acc.name %> (****<%= acc.number %>) — $<%= Number(acc.balance || 0).toFixed(2) %></option>
                <% }); %>
              </select>
            </div>

            <div class="form-group">
              <label class="form-label">To Account</label>
              <select name="toAccount" class="form-select" required>
                <option value="">Select destination</option>
                <% acctList.forEach(function(acc) { %>
                  <option value="<%= acc.id %>"><%= acc.name %> (****<%= acc.number %>)</option>
                <% }); %>
              </select>
            </div>

            <div class="form-group">
              <label class="form-label">Amount</label>
              <div style="position:relative;">
                <span style="position:absolute;left:12px;top:50%;transform:translateY(-50%);color:var(--text-secondary);">$</span>
                <input type="number" name="amount" class="form-input" placeholder="0.00" min="0.01" step="0.01" required style="padding-left:28px;">
              </div>
            </div>

            <div class="form-group">
              <label class="form-label">Memo (Optional)</label>
              <input type="text" name="memo" class="form-input" placeholder="Add a note">
            </div>

            <button type="submit" class="btn-submit">Transfer Funds</button>
          </form>

          <!-- 2. DOMESTIC WIRE FORM -->
          <form id="form-domestic" class="form-card hidden" action="/transfer" method="POST">
            <input type="hidden" name="transferType" value="domestic">
            <h3>Domestic Wire Transfer</h3>
            
            <div class="form-group">
              <label class="form-label">From Account</label>
              <select name="fromAccount" class="form-select" required>
                <option value="">Select source</option>
                <% acctList.forEach(function(acc) { %>
                  <option value="<%= acc.id %>"><%= acc.name %> (****<%= acc.number %>) — $<%= Number(acc.balance || 0).toFixed(2) %></option>
                <% }); %>
              </select>
            </div>

            <div class="form-row">
              <div class="form-group">
                <label class="form-label">Recipient Name</label>
                <input type="text" name="recipientName" class="form-input" placeholder="Full legal name" required>
              </div>
              <div class="form-group">
                <label class="form-label">Bank Name</label>
                <input type="text" name="bankName" class="form-input" placeholder="Bank Name" required>
              </div>
            </div>

            <div class="form-row">
              <div class="form-group">
                <label class="form-label">Routing Number (9 digits)</label>
                <input type="text" name="routingNumber" class="form-input" placeholder="000000000" pattern="[0-9]{9}" maxlength="9" required>
              </div>
              <div class="form-group">
                <label class="form-label">Account Number</label>
                <input type="text" name="accountNumber" class="form-input" placeholder="Recipient Account #" required>
              </div>
            </div>

            <div class="form-group">
              <label class="form-label">Amount</label>
              <div style="position:relative;">
                <span style="position:absolute;left:12px;top:50%;transform:translateY(-50%);color:var(--text-secondary);">$</span>
                <input type="number" name="amount" class="form-input" placeholder="0.00" min="0.01" step="0.01" required style="padding-left:28px;">
              </div>
            </div>

            <button type="submit" class="btn-submit">Send Wire ($25 fee)</button>
          </form>

          <!-- 3. INTERNATIONAL WIRE FORM -->
          <form id="form-international" class="form-card hidden" action="/transfer" method="POST">
            <input type="hidden" name="transferType" value="international">
            <h3>International Wire</h3>
            
            <div class="form-group">
              <label class="form-label">From Account</label>
              <select name="fromAccount" class="form-select" required>
                <option value="">Select source</option>
                <% acctList.forEach(function(acc) { %>
                  <option value="<%= acc.id %>"><%= acc.name %> (****<%= acc.number %>) — $<%= Number(acc.balance || 0).toFixed(2) %></option>
                <% }); %>
              </select>
            </div>

            <div class="form-group">
              <label class="form-label">Recipient Name</label>
              <input type="text" name="recipientName" class="form-input" placeholder="Full legal name" required>
            </div>

            <div class="form-group">
              <label class="form-label">SWIFT / BIC Code</label>
              <input type="text" name="swiftCode" class="form-input" placeholder="e.g. BOFAUS3N" required>
            </div>

            <div class="form-group">
              <label class="form-label">Account / IBAN</label>
              <input type="text" name="accountNumber" class="form-input" placeholder="International account number" required>
            </div>

            <div class="form-group">
              <label class="form-label">Amount</label>
              <div style="position:relative;">
                <span style="position:absolute;left:12px;top:50%;transform:translateY(-50%);color:var(--text-secondary);">$</span>
                <input type="number" name="amount" class="form-input" placeholder="0.00" min="0.01" step="0.01" required style="padding-left:28px;">
              </div>
            </div>

            <button type="submit" class="btn-submit">Send International Wire ($45 fee)</button>
          </form>

        </div>

        <!-- RIGHT SIDEBAR -->
        <div class="animate">
          <div class="summary-card">
            <h4>Your Accounts</h4>
            <% acctList.forEach(function(acc) { %>
              <div class="quick-acct" onclick="selectAcct('<%= acc.id %>')">
                <div class="quick-acct-icon"><%= acc.icon || '🏦' %></div>
                <div class="quick-acct-info">
                  <div class="quick-acct-name"><%= acc.name %></div>
                  <div class="quick-acct-num">****<%= acc.number %></div>
                </div>
                <div class="quick-acct-bal">$<%= Number(acc.balance || 0).toFixed(2) %></div>
              </div>
            <% }); %>
            
            <div style="height:1px; background:var(--border); margin:1rem 0;"></div>
            
            <h4>Limits & Fees</h4>
            <div class="summary-row"><span class="label">Daily Limit</span><span class="value">$50,000.00</span></div>
            <div class="summary-row"><span class="label">Internal</span><span class="value" style="color:var(--success)">Free</span></div>
            <div class="summary-row"><span class="label">Domestic</span><span class="value">$25.00</span></div>
            <div class="summary-row"><span class="label">International</span><span class="value">$45.00</span></div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <nav class="mobile-nav">
    <div class="mobile-nav-grid">
      <a href="/dashboard" class="mob-nav-item"><span class="mob-icon">📊</span>Home</a>
      <a href="/accounts" class="mob-nav-item"><span class="mob-icon">💳</span>Accounts</a>
      <a href="/transfer" class="mob-nav-item active"><span class="mob-icon">⇄</span>Transfer</a>
      <a href="/billpay" class="mob-nav-item"><span class="mob-icon">💸</span>Pay</a>
      <a href="/profile" class="mob-nav-item"><span class="mob-icon">👤</span>Profile</a>
    </div>
  </nav>

  <script>
    function toggleSidebar() {
      document.getElementById('sidebar').classList.toggle('open');
      document.getElementById('sidebarOverlay').classList.toggle('show');
    }
    function showForm(id, btn) {
      document.querySelectorAll('.form-card').forEach(f => f.classList.add('hidden'));
      document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
      document.getElementById('form-' + id).classList.remove('hidden');
      btn.classList.add('active');
    }
    function selectAcct(id) {
      document.querySelectorAll('.quick-acct').forEach(e => e.classList.remove('selected'));
      event.currentTarget.classList.add('selected');
      document.querySelectorAll('select[name="fromAccount"]').forEach(s => {
        for(var i=0; i<s.options.length; i++) { if(s.options[i].value === id) s.value = id; }
      });
    }
  </script>
</body>
</html>
