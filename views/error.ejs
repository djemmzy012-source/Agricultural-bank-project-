<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Error - AgriBank Texas</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body class="auth-shell">
    <div class="auth-panel" style="text-align: center; max-width: 500px;">
        <h1 style="color: #d32f2f; font-size: 3rem; margin-bottom: 1rem;">Oops!</h1>
        <h3><%= message %></h3>
        <p class="muted" style="margin-bottom: 2rem;">Error Code: <%= typeof code !== 'undefined' ? code : '500' %></p>
        <a href="/" class="btn btn-primary">Return to Home</a>
    </div>
</body>
</html>