<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
  <title>Accounts | AgriBank Texas</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&family=DM+Serif+Display&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
  <style>
    /* Page-specific styles */
    .accounts-header {
      margin-bottom: var(--spacing-lg);
    }
    .accounts-grid {
      display: grid;
      gap: var(--spacing-md);
      margin-bottom: var(--spacing-xl);
    }
    .account-card {
      background: var(--bg-white);
      border-radius: var(--radius-md);
      padding: var(--spacing-lg);
      box-shadow: var(--shadow-sm);
      border-left: 4px solid var(--green-main);
      transition: var(--transition);
      display: flex;
      flex-direction: column;
      gap: var(--spacing-sm);
    }
    .account-card:hover {
      box-shadow: var(--shadow-md);
      transform: translateY(-2px);
    }
    .account-card.savings { border-left-color: var(--green-light); }
    .account-card.business { border-left-color: var(--gold); }
    
    .account-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: var(--spacing-sm);
    }
    .account-icon {
      font-size: 1.5rem;
      width: 44px;
      height: 44px;
      display: flex;
      align-items: center;
      justify-content: center;
      background: var(--green-pale);
      border-radius: 10px;
      flex-shrink: 0;
    }
    .account-details {
      flex: 1;
      min-width: 0;
    }
    .account-name {
      font-weight: 600;
      font-size: 1rem;
      color: var(--text-dark);
      margin-bottom: 2px;
    }
    .account-number {
      font-family: var(--font-mono);
      font-size: 0.875rem;
      color: var(--text-light);
    }
    .account-balance {
      font-family: var(--font-serif);
      font-size: clamp(1.5rem, 4vw, 2rem);
      font-weight: 700;
      color: var(--green-dark);
      margin: var(--spacing-sm) 0;
    }
    .account-actions {
      display: flex;
      gap: var(--spacing-sm);
      flex-wrap: wrap;
      margin-top: var(--spacing-sm);
    }
    .btn-view {
      padding: 8px 16px;
      font-size: 0.875rem;
      min-height: 40px;
    }
    
    .empty-state {
      text-align: center;
      padding: var(--spacing-xl);
      color: var(--text-mid);
    }
    .empty-state p { margin-bottom: var(--spacing-md); }
    
    /* Mobile optimizations */
    @media (max-width: 768px) {
      .account-card {
        padding: var(--spacing-md);
      }
      .account-header {
        flex-direction: column;
        align-items: flex-start;
        gap: var(--spacing-sm);
      }
      .account-actions {
        width: 100%;
        justify-content: flex-start;
      }
      .btn-view {
        width: 100%;
        max-width: 200px;
        text-align: center;
      }
    }
    
    @media (max-width: 480px) {
      .container { padding: 0 var(--spacing-md); }
      .account-card { padding: var(--spacing-sm); }
      .account-balance { font-size: 1.5rem; }
      .account-name { font-size: 0.95rem; }
      .account-number { font-size: 0.8rem; }
    }
  </style>
</head>
<body>
  <!-- Navbar Partial -->
  <%- include('partials/navbar', { user: user }) %>

  <!-- Main Content -->
  <main class="container page-content">
    <div class="accounts-header">
      <h1>Your Accounts</h1>
      <p class="auth-subtitle">Welcome back, <%= user.firstName %></p>
    </div>

    <% if (accounts && accounts.length > 0) { %>
      <div class="accounts-grid">
        <% accounts.forEach(function(account) { %>
          <article class="account-card <%= account.type %>">
            <div class="account-header">
              <div class="account-icon"><%= account.icon || '🏦' %></div>
              <div class="account-details">
                <h3 class="account-name"><%= account.name %></h3>
                <p class="account-number"><%= account.number %> · <%= account.type %></p>
              </div>
            </div>
            
            <div class="account-balance">
              $<%= account.balance.toLocaleString('en-US', { minimumFractionDigits: 2 }) %>
            </div>
            
            <div class="account-actions">
              <a href="/transactions?accountId=<%= account.id %>" class="btn btn-primary btn-view">
                View Transactions
              </a>
              <a href="/transfer?from=<%= account.id %>" class="btn btn-outline btn-view">
                Transfer
              </a>
            </div>
          </article>
        <% }); %>
      </div>
    <% } else { %>
      <div class="card empty-state">
        <h3>No accounts yet</h3>
        <p>Open your first account to get started.</p>
        <a href="/register" class="btn btn-primary">Open an Account</a>
      </div>
    <% } %>
  </main>

  <!-- Footer Partial -->
  <%- include('partials/footer') %>

  <!-- Mobile nav toggle script -->
  <script>
    // Simple mobile nav toggle
    document.addEventListener('DOMContentLoaded', () => {
      const toggle = document.querySelector('.menu-toggle');
      const navLinks = document.querySelector('.nav-links');
      if (toggle && navLinks) {
        toggle.addEventListener('click', () => {
          navLinks.classList.toggle('active');
        });
      }
    });
  </script>
</body>
</html>