<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Terms of Service | AgriBank Texas Regional</title>
  <link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display&family=DM+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
  <style>
    :root {
      --navy: #0a1c14;
      --green-900: #0f2b1f;
      --green-800: #144a25;
      --green-700: #1a5c30;
      --green-600: #22753d;
      --gold: #d4a047;
      --gold-light: #e8b85e;
      --bg: #f8faf8;
      --surface: #ffffff;
      --text: #0f172a;
      --text-secondary: #64748b;
      --border: #e2e8f0;
      --sidebar-w: 260px;
    }

    * { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: 'DM Sans', sans-serif;
      background: var(--bg);
      color: var(--text);
      line-height: 1.7;
      overflow-x: hidden;
    }

    a { text-decoration: none; color: inherit; transition: 0.2s; }

    /* ==========================================
       NAVIGATION
       ========================================== */
    .navbar {
      position: fixed; top: 0; left: 0; right: 0;
      background: rgba(255,255,255,0.95);
      backdrop-filter: blur(20px);
      border-bottom: 1px solid var(--border);
      z-index: 200;
      height: 64px;
      display: flex; align-items: center; justify-content: space-between;
      padding: 0 2rem;
    }
    .nav-brand { font-family: 'DM Serif Display', serif; font-size: 1.4rem; color: var(--green-900); }
    .nav-brand span { color: var(--gold); }
    .nav-links { display: flex; gap: 2rem; align-items: center; }
    .nav-links a { color: var(--text-secondary); font-weight: 600; font-size: 0.9rem; }
    .nav-links a:hover { color: var(--green-700); }
    .btn-nav { background: var(--green-800) !important; color: white !important; padding: 0.5rem 1.25rem; border-radius: 8px; }
    .btn-nav:hover { background: var(--green-700) !important; }

    /* ==========================================
       HERO SECTION
       ========================================== */
    .page-hero {
      background: linear-gradient(170deg, var(--green-900) 0%, #1a5c30 40%, #2ea55a 100%);
      color: white;
      padding: 7rem 2rem 3.5rem;
      text-align: center;
      position: relative;
      overflow: hidden;
    }
    .page-hero::before {
      content: '';
      position: absolute; inset: 0;
      background: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='0.03'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
    }
    .hero-badge {
      display: inline-flex; align-items: center; gap: 0.5rem;
      background: rgba(255,255,255,0.12);
      border: 1px solid rgba(255,255,255,0.2);
      border-radius: 50px;
      padding: 0.4rem 1.15rem;
      font-size: 0.75rem; font-weight: 700; text-transform: uppercase;
      letter-spacing: 1.5px; color: var(--gold-light);
      margin-bottom: 1.5rem; position: relative;
    }
    .page-hero h1 {
      font-family: 'DM Serif Display', serif;
      font-size: clamp(2.2rem, 5vw, 3.2rem);
      line-height: 1.15;
      margin-bottom: 1rem;
      position: relative;
    }
    .page-hero p {
      max-width: 600px; margin: 0 auto;
      color: rgba(255,255,255,0.75);
      font-size: 1.05rem;
      position: relative;
    }

    /* ==========================================
       CONTENT LAYOUT
       ========================================== */
    .content-layout {
      max-width: 1200px;
      margin: 0 auto;
      display: grid;
      grid-template-columns: 240px 1fr;
      gap: 2.5rem;
      padding: 3rem 2rem 4rem;
    }

    /* SIDEBAR TABLE OF CONTENTS */
    .toc-sidebar {
      position: sticky;
      top: 80px;
      align-self: start;
      background: var(--surface);
      border-radius: 14px;
      padding: 1.25rem;
      border: 1px solid var(--border);
      box-shadow: 0 1px 6px rgba(0,0,0,0.04);
    }
    .toc-title {
      font-size: 0.65rem;
      text-transform: uppercase;
      letter-spacing: 1.5px;
      color: var(--text-secondary);
      font-weight: 700;
      margin-bottom: 0.75rem;
      padding-bottom: 0.5rem;
      border-bottom: 1px solid var(--border);
    }
    .toc-list { list-style: none; }
    .toc-list li { margin-bottom: 0.15rem; }
    .toc-list a {
      display: block;
      padding: 0.45rem 0.65rem;
      border-radius: 6px;
      font-size: 0.78rem;
      color: var(--text-secondary);
      font-weight: 500;
      transition: all 0.2s;
      line-height: 1.4;
    }
    .toc-list a:hover { background: #f0fdf4; color: var(--green-700); }
    .toc-list a.active { background: #ecfdf5; color: var(--green-700); font-weight: 700; }

    /* MAIN CONTENT AREA */
    .main-content { min-width: 0; }

    /* TERMS SECTIONS */
    .t-section {
      scroll-margin-top: 80px;
      margin-bottom: 3rem;
      animation: fadeInUp 0.5s ease both;
    }
    .t-section:nth-child(1) { animation-delay: 0.05s; }
    .t-section:nth-child(2) { animation-delay: 0.1s; }
    .t-section:nth-child(3) { animation-delay: 0.15s; }
    .t-section:nth-child(4) { animation-delay: 0.2s; }
    .t-section:nth-child(5) { animation-delay: 0.25s; }
    .t-section:nth-child(6) { animation-delay: 0.3s; }
    .t-section:nth-child(7) { animation-delay: 0.35s; }
    .t-section:nth-child(8) { animation-delay: 0.4s; }

    .section-header {
      display: flex; align-items: center; gap: 0.75rem;
      margin-bottom: 0.75rem;
    }
    .section-number {
      font-family: 'DM Serif Display', serif;
      font-size: 1.1rem;
      color: var(--gold);
      font-weight: 700;
      min-width: 28px;
    }
    .t-section h2 {
      font-family: 'DM Serif Display', serif;
      font-size: 1.55rem;
      color: var(--green-900);
      line-height: 1.3;
    }
    .t-section h3 {
      font-size: 1.05rem;
      font-weight: 700;
      margin-top: 1.5rem;
      margin-bottom: 0.5rem;
      color: var(--text);
    }
    .t-section > p, .t-section li {
      color: var(--text-secondary);
      font-size: 0.92rem;
      margin-bottom: 0.75rem;
      line-height: 1.8;
    }
    .t-section ul {
      padding-left: 1.25rem;
      margin-bottom: 0.75rem;
    }
    .t-section li { margin-bottom: 0.35rem; }
    .t-section li::marker { color: var(--gold); }

    .highlight-box {
      background: linear-gradient(135deg, #fffbeb, #fefce8);
      border-left: 4px solid var(--gold);
      border-radius: 0 10px 10px 0;
      padding: 1.25rem 1.5rem;
      margin: 1.25rem 0;
    }
    .highlight-box p {
      color: #92400e;
      font-size: 0.88rem;
      margin-bottom: 0;
      line-height: 1.7;
    }
    .highlight-box strong { color: #78350f; }

    .info-banner {
      background: #f0fdf4;
      border: 1px solid #bbf7d0;
      border-radius: 10px;
      padding: 1.25rem 1.5rem;
      margin: 1.25rem 0;
      display: flex; align-items: flex-start; gap: 0.75rem;
    }
    .info-banner-icon { font-size: 1.2rem; flex-shrink: 0; margin-top: 2px; }
    .info-banner p { color: #166534; font-size: 0.88rem; line-height: 1.7; margin: 0; }

    .term-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
      gap: 0.75rem;
      margin: 1rem 0;
    }
    .term-item {
      background: #f8fafc;
      border-radius: 10px;
      padding: 1rem 1.25rem;
      border: 1px solid var(--border);
    }
    .term-item-label {
      font-size: 0.68rem;
      text-transform: uppercase;
      letter-spacing: 1px;
      color: var(--text-secondary);
      font-weight: 600;
      margin-bottom: 0.25rem;
    }
    .term-item-value {
      font-size: 0.9rem;
      font-weight: 600;
      color: var(--text);
    }

    /* BUTTONS */
    .btn-back-top {
      display: inline-flex; align-items: center; gap: 0.5rem;
      background: var(--green-800); color: white;
      padding: 0.75rem 1.5rem; border-radius: 10px;
      font-size: 0.85rem; font-weight: 600;
      transition: all 0.2s; cursor: pointer; border: none;
      margin-top: 1rem;
    }
    .btn-back-top:hover { background: var(--green-700); transform: translateY(-2px); }

    /* FOOTER */
    .footer {
      background: var(--navy);
      color: rgba(255,255,255,0.5);
      padding: 3rem 2rem;
      text-align: center;
      font-size: 0.85rem;
    }
    .footer-brand {
      font-family: 'DM Serif Display', serif;
      font-size: 1.3rem;
      color: white;
      margin-bottom: 0.25rem;
    }
    .footer-brand span { color: var(--gold); }
    .footer-subtitle {
      font-size: 0.65rem;
      text-transform: uppercase;
      letter-spacing: 1.5px;
      opacity: 0.5;
      margin-bottom: 1.5rem;
    }
    .footer-links {
      display: flex; justify-content: center; gap: 1.5rem;
      margin-bottom: 1.25rem; flex-wrap: wrap;
    }
    .footer-links a {
      color: rgba(255,255,255,0.6); font-weight: 600;
      font-size: 0.85rem;
    }
    .footer-links a:hover { color: var(--gold); }

    /* MOBILE BOTTOM NAV */
    .mobile-nav {
      display: none;
      position: fixed; bottom: 0; left: 0; right: 0;
      background: white; border-top: 1px solid var(--border);
      z-index: 100; padding: 0.5rem 0;
      padding-bottom: max(0.5rem, env(safe-area-inset-bottom));
      box-shadow: 0 -4px 20px rgba(0,0,0,0.06);
    }
    .mobile-nav-grid { display: grid; grid-template-columns: repeat(5, 1fr); }
    .mob-nav-item {
      display: flex; flex-direction: column; align-items: center;
      gap: 0.2rem; padding: 0.5rem 0;
      font-size: 0.6rem; font-weight: 600;
      color: var(--text-secondary); cursor: pointer;
    }
    .mob-nav-item.active { color: var(--green-700); }
    .mob-nav-item .mob-icon { font-size: 1.25rem; }

    /* ANIMATIONS */
    @keyframes fadeInUp {
      from { opacity: 0; transform: translateY(15px); }
      to { opacity: 1; transform: translateY(0); }
    }

    /* RESPONSIVE */
    @media (max-width: 1024px) {
      .content-layout { grid-template-columns: 1fr; }
      .toc-sidebar {
        position: static;
        display: flex; gap: 1rem; flex-wrap: wrap;
        padding: 1rem;
      }
      .toc-title { width: 100%; }
      .toc-list { display: flex; gap: 0.5rem; flex-wrap: wrap; }
      .toc-list a { white-space: nowrap; }
    }
    @media (max-width: 768px) {
      .navbar { padding: 0 1rem; }
      .nav-links { display: none; }
      .content-layout { padding: 2rem 1rem 5rem; }
      .page-hero { padding: 5.5rem 1rem 2.5rem; }
      .mobile-nav { display: block; }
      .t-section h2 { font-size: 1.3rem; }
    }
  </style>
</head>
<body>

  <!-- ========== NAVBAR ========== -->
  <nav class="navbar">
    <a href="/" class="nav-brand">Agri<span>Bank</span></a>
    <div class="nav-links">
