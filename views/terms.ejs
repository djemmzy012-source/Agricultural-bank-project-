      <a href="/register" class="btn-nav">Open Account</a>
    </div>
  </nav>

  <!-- ========== HERO ========== -->
  <section class="page-hero">
    <div class="hero-badge">📄 Legal Agreement</div>
    <h1>Terms of Service</h1>
    <p>Please read these Terms of Service carefully before using any AgriBank Texas Regional services. Your access to and use of our platform is conditioned on your acceptance of and compliance with these terms.</p>
  </section>

  <!-- ========== CONTENT ========== -->
  <div class="content-layout">

    <!-- SIDEBAR TOC -->
    <aside class="toc-sidebar">
      <div class="toc-title">Contents</div>
      <ul class="toc-list">
        <li><a href="#t1" class="active">Acceptance of Terms</a></li>
        <li><a href="#t2">Account Eligibility</a></li>
