<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('partials/head', { title: 'Dashboard | AgriBank Texas' }) %>
  <style>
    /* =============================================
       AGRI BANK DASHBOARD — PREMIUM DESIGN
       ============================================= */
    :root {
      --navy: #0a1c14;
      --green-900: #0f2b1f;
      --green-800: #144a25;
      --green-700: #1a5c30;
      --green-600: #22753d;
      --gold: #d4a047;
      --gold-light: #e8b85e;
      --bg: #f0f2f5;
      --surface: #ffffff;
      --text: #0f172a;
      --text-secondary: #64748b;
      --border: #e2e8f0;
      --success: #10b981;
      --danger: #ef4444;
      --info: #3b82f6;
      --sidebar-w: 260px;
      --header-h: 72px;
      --radius: 16px;
      --radius-sm: 10px;
      --shadow: 0 1px 3px rgba(0,0,0,0.06), 0 4px 12px rgba(0,0,0,0.04);
      --shadow-lg: 0 8px 30px rgba(0,0,0,0.08);
    }

    * { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }

    body {
      font-family: 'DM Sans', -apple-system, BlinkMacSystemFont, sans-serif;
      background: var(--bg);
      color: var(--text);
      line-height: 1.5;
      overflow-x: hidden;
      -webkit-font-smoothing: antialiased;
    }

    a { text-decoration: none; color: inherit; transition: 0.2s; }

    /* =============================================
       SIDEBAR NAVIGATION (Desktop)
       ============================================= */
    .sidebar {
      position: fixed;
      top: 0; left: 0;
      width: var(--sidebar-w);
      height: 100vh;
      background: var(--green-900);
      color: white;
      z-index: 100;
      display: flex;
      flex-direction: column;
      transition: transform 0.3s ease;
      overflow-y: auto;
    }

    .sidebar-brand {
      padding: 1.75rem 1.5rem;
      border-bottom: 1px solid rgba(255,255,255,0.08);
    }
    .sidebar-brand h2 {
      font-family: 'DM Serif Display', serif;
      font-size: 1.35rem;
      letter-spacing: -0.3px;
    }
    .sidebar-brand span { color: var(--gold); }
    .sidebar-brand .sub {
      font-size: 0.65rem;
      text-transform: uppercase;
      letter-spacing: 1.5px;
      opacity: 0.5;
      margin-top: 0.25rem;
      font-weight: 600;
    }

    .sidebar-nav { padding: 1.25rem 1rem; flex: 1; }

    .nav-section {
      font-size: 0.6rem;
      text-transform: uppercase;
      letter-spacing: 1.5px;
      opacity: 0.35;
      padding: 0.75rem 0.75rem 0.4rem;
      font-weight: 700;
    }

    .nav-item {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      padding: 0.7rem 0.85rem;
      border-radius: var(--radius-sm);
      font-size: 0.875rem;
      font-weight: 500;
      color: rgba(255,255,255,0.65);
      margin-bottom: 2px;
      transition: all 0.2s;
      cursor: pointer;
    }
    .nav-item:hover {
      background: rgba(255,255,255,0.08);
      color: white;
    }
    .nav-item.active {
      background: rgba(212, 160, 71, 0.15);
      color: var(--gold);
      font-weight: 600;
    }
    .nav-item .icon {
      width: 20px;
      text-align: center;
      font-size: 1rem;
      opacity: 0.85;
    }
    .nav-item .badge-dot {
      width: 6px; height: 6px;
      background: var(--gold);
      border-radius: 50%;
      margin-left: auto;
    }

    .sidebar-footer {
      padding: 1.25rem;
      border-top: 1px solid rgba(255,255,255,0.08);
    }
    .sidebar-user {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      padding: 0.5rem;
      border-radius: var(--radius-sm);
      cursor: pointer;
    }
    .sidebar-user:hover { background: rgba(255,255,255,0.05); }
    .avatar {
      width: 36px; height: 36px;
      border-radius: 50%;
      background: var(--gold);
      display: flex; align-items: center; justify-content: center;
      font-weight: 700;
      font-size: 0.85rem;
      color: var(--green-900);
    }
    .user-info .name { font-size: 0.85rem; font-weight: 600; }
    .user-info .role { font-size: 0.7rem; opacity: 0.5; }

    /* =============================================
       MAIN CONTENT AREA
       ============================================= */
    .main {
      margin-left: var(--sidebar-w);
      min-height: 100vh;
      display: flex;
      flex-direction: column;
    }

    /* TOP HEADER BAR */
    .topbar {
      position: sticky;
      top: 0;
      height: var(--header-h);
      background: rgba(255,255,255,0.85);
      backdrop-filter: blur(20px);
      border-bottom: 1px solid var(--border);
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0 2rem;
      z-index: 50;
    }

    .topbar-left { display: flex; align-items: center; gap: 1rem; }
    .hamburger {
      display: none;
      background: none;
      border: none;
      font-size: 1.5rem;
      cursor: pointer;
      padding: 0.25rem;
      color: var(--text);
    }
    .topbar-title h1 {
      font-size: 1.15rem;
      font-weight: 700;
      color: var(--text);
    }
    .topbar-title .date {
      font-size: 0.75rem;
      color: var(--text-secondary);
    }

    .topbar-right { display: flex; align-items: center; gap: 0.75rem; }
    .topbar-btn {
      width: 40px; height: 40px;
      border-radius: 50%;
      background: transparent;
      border: 1px solid var(--border);
      display: flex; align-items: center; justify-content: center;
      font-size: 1.1rem;
      cursor: pointer;
      transition: all 0.2s;
      position: relative;
    }
    .topbar-btn:hover { background: #f8fafc; border-color: #cbd5e1; }
    .notif-dot {
      position: absolute;
      top: 8px; right: 8px;
      width: 7px; height: 7px;
      background: var(--danger);
      border-radius: 50%;
      border: 2px solid white;
    }

    /* =============================================
       CONTENT WRAPPER
       ============================================= */
    .content { padding: 2rem; max-width: 1400px; margin: 0 auto; flex: 1; }

    /* =============================================
       CARDS / WIDGETS
       ============================================= */
    .widget {
      background: var(--surface);
      border-radius: var(--radius);
      box-shadow: var(--shadow);
      overflow: hidden;
      transition: box-shadow 0.3s, transform 0.2s;
    }
    .widget:hover { box-shadow: var(--shadow-lg); }

    .widget-header {
      padding: 1.25rem 1.5rem;
      display: flex;
      align-items: center;
      justify-content: space-between;
      border-bottom: 1px solid var(--border);
    }
    .widget-header h3 {
      font-size: 0.95rem;
      font-weight: 700;
    }
    .widget-body { padding: 1.5rem; }

    /* =============================================
       KPI CARDS (Row 1)
       ============================================= */
    .kpi-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 1.25rem;
      margin-bottom: 1.5rem;
    }

    .kpi-card {
      background: var(--surface);
      border-radius: var(--radius);
      padding: 1.5rem;
      box-shadow: var(--shadow);
      display: flex;
      flex-direction: column;
      gap: 0.75rem;
      transition: transform 0.2s, box-shadow 0.3s;
      position: relative;
      overflow: hidden;
    }
    .kpi-card:hover { transform: translateY(-2px); box-shadow: var(--shadow-lg); }

    .kpi-card.primary {
      background: linear-gradient(135deg, var(--green-900), var(--green-700));
      color: white;
    }
    .kpi-card.primary .kpi-label,
    .kpi-card.primary .kpi-trend { color: rgba(255,255,255,0.7); }
    .kpi-card.primary .kpi-value { color: white; }

    .kpi-label {
      font-size: 0.75rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.8px;
      color: var(--text-secondary);
    }

    .kpi-value {
      font-size: 1.85rem;
      font-weight: 800;
      font-family: 'DM Serif Display', serif;
      line-height: 1.1;
    }

    .kpi-trend {
      font-size: 0.75rem;
      font-weight: 600;
      display: flex;
      align-items: center;
      gap: 0.3rem;
    }
    .kpi-trend.up { color: var(--success); }
    .kpi-trend.down { color: var(--danger); }

    .kpi-icon {
      position: absolute;
      top: 1.25rem;
      right: 1.25rem;
      width: 42px; height: 42px;
      border-radius: 12px;
      display: flex; align-items: center; justify-content: center;
      font-size: 1.2rem;
    }
    .kpi-card:not(.primary) .kpi-icon { background: #f0fdf4; }
    .kpi-card.primary .kpi-icon { background: rgba(255,255,255,0.15); }

    /* =============================================
       QUICK ACTIONS (Row 2)
       ============================================= */
    .actions-grid {
      display: grid;
      grid-template-columns: repeat(5, 1fr);
      gap: 1rem;
      margin-bottom: 1.5rem;
    }

    .action-item {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 1.5rem 1rem;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 0.75rem;
      cursor: pointer;
      transition: all 0.25s;
    }
    .action-item:hover {
      border-color: var(--gold);
      background: #fefce8;
      transform: translateY(-3px);
      box-shadow: 0 8px 20px rgba(212, 160, 71, 0.15);
    }
    .action-icon {
      width: 48px; height: 48px;
      border-radius: 14px;
      background: linear-gradient(135deg, var(--green-800), var(--green-600));
      display: flex; align-items: center; justify-content: center;
      font-size: 1.3rem;
      color: white;
      transition: transform 0.3s;
    }
    .action-item:hover .action-icon { transform: scale(1.1); }
    .action-label {
      font-size: 0.8rem;
      font-weight: 600;
      color: var(--text);
      text-align: center;
    }

    /* =============================================
       MAIN TWO-COLUMN LAYOUT
       ============================================= */
    .main-grid {
      display: grid;
      grid-template-columns: 1fr 380px;
      gap: 1.5rem;
    }

    /* =============================================
       ACCOUNTS
       ============================================= */
    .account-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 1rem;
    }

    .acct-card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 1.25rem;
      transition: all 0.25s;
      position: relative;
      overflow: hidden;
    }
    .acct-card::before {
      content: '';
      position: absolute;
      top: 0; left: 0;
      width: 4px; height: 100%;
      background: var(--green-600);
    }
    .acct-card.checking::before { background: #3b82f6; }
    .acct-card.savings::before { background: var(--success); }
    .acct-card.business::before { background: var(--gold); }

    .acct-card:hover {
      border-color: var(--green-600);
      box-shadow: var(--shadow-lg);
      transform: translateY(-2px);
    }

    .acct-top { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 1rem; }
    .acct-icon-wrap {
      width: 40px; height: 40px;
      border-radius: 10px;
      display: flex; align-items: center; justify-content: center;
      font-size: 1.2rem;
    }
    .acct-card.checking .acct-icon-wrap { background: #eff6ff; }
    .acct-card.savings .acct-icon-wrap { background: #ecfdf5; }
    .acct-card.business .acct-icon-wrap { background: #fefce8; }

    .acct-status {
      font-size: 0.6rem;
      text-transform: uppercase;
      letter-spacing: 1px;
      font-weight: 700;
      color: var(--success);
      background: #ecfdf5;
      padding: 0.2rem 0.5rem;
      border-radius: 20px;
    }

    .acct-name { font-weight: 700; font-size: 0.9rem; margin-bottom: 0.15rem; }
    .acct-number { font-size: 0.75rem; color: var(--text-secondary); font-family: 'JetBrains Mono', monospace; margin-bottom: 0.75rem; }
    .acct-bal {
      font-size: 1.35rem;
      font-weight: 800;
      font-family: 'DM Serif Display', serif;
      color: var(--text);
      margin-bottom: 0.15rem;
    }
    .acct-bal-label { font-size: 0.65rem; color: var(--text-secondary); text-transform: uppercase; letter-spacing: 0.5px; font-weight: 600; }

    .acct-actions {
      display: flex; gap: 0.5rem; margin-top: 1rem;
    }
    .acct-btn {
      flex: 1;
      padding: 0.45rem;
      border-radius: 8px;
      font-size: 0.7rem;
      font-weight: 600;
      text-align: center;
      border: 1px solid var(--border);
      background: transparent;
      cursor: pointer;
      transition: all 0.2s;
    }
    .acct-btn:hover { background: #f8fafc; border-color: #cbd5e1; }
    .acct-btn.primary-btn {
      background: var(--green-800);
      color: white;
      border-color: var(--green-800);
    }
    .acct-btn.primary-btn:hover { background: var(--green-700); }

    /* =============================================
       TRANSACTIONS TABLE
       ============================================= */
    .tx-list { display: flex; flex-direction: column; }
    .tx-row {
      display: flex;
      align-items: center;
      padding: 0.85rem 0;
      border-bottom: 1px solid #f1f5f9;
      transition: background 0.15s;
    }
    .tx-row:last-child { border-bottom: none; }
    .tx-row:hover { background: #fafbfc; }

    .tx-icon {
      width: 40px; height: 40px;
      border-radius: 10px;
      display: flex; align-items: center; justify-content: center;
      font-size: 1rem;
      margin-right: 0.85rem;
      flex-shrink: 0;
    }
    .tx-icon.in { background: #ecfdf5; }
    .tx-icon.out { background: #fef2f2; }

    .tx-details { flex: 1; min-width: 0; }
    .tx-name { font-weight: 600; font-size: 0.85rem; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .tx-meta { font-size: 0.7rem; color: var(--text-secondary); margin-top: 0.15rem; }
    .tx-amount { font-weight: 700; font-size: 0.9rem; text-align: right; white-space: nowrap; }
    .tx-amount.in { color: var(--success); }
    .tx-amount.out { color: var(--text); }

    /* =============================================
       CHART
       ============================================= */
    .chart-wrap {
      display: flex;
      align-items: flex-end;
      gap: 8px;
      height: 180px;
      padding-top: 10px;
    }
    .chart-bar-group {
      flex: 1;
      display: flex;
      flex-direction: column;
      align-items: center;
      height: 100%;
      justify-content: flex-end;
    }
    .chart-bar {
      width: 100%;
      max-width: 32px;
      border-radius: 6px 6px 2px 2px;
      background: linear-gradient(to top, var(--green-700), var(--green-500, #2ea55a));
      transition: height 0.8s cubic-bezier(0.4, 0, 0.2, 1), background 0.2s;
      position: relative;
    }
    .chart-bar:hover { background: linear-gradient(to top, var(--green-600), #36d399); }
    .chart-month {
      font-size: 0.65rem;
      color: var(--text-secondary);
      font-weight: 600;
      margin-top: 0.5rem;
    }

    /* =============================================
       RIGHT SIDEBAR WIDGETS
       ============================================= */
    .right-stack {
      display: flex;
      flex-direction: column;
      gap: 1.25rem;
    }

    /* Credit Score */
    .credit-score-card {
      background: linear-gradient(135deg, var(--green-900), var(--green-700));
      color: white;
      border-radius: var(--radius);
      padding: 1.5rem;
      text-align: center;
    }
    .credit-ring {
      width: 100px; height: 100px;
      border-radius: 50%;
      border: 8px solid rgba(255,255,255,0.15);
      border-top-color: var(--gold);
      border-right-color: var(--gold);
      border-left-color: var(--gold);
      display: flex;
      align-items: center;
      justify-content: center;
      margin: 0.75rem auto;
      position: relative;
    }
    .credit-ring .score { font-size: 2rem; font-weight: 800; font-family: 'DM Serif Display', serif; }
    .credit-label { font-size: 0.65rem; text-transform: uppercase; letter-spacing: 1.5px; opacity: 0.7; font-weight: 600; }
    .credit-badge {
      display: inline-block;
      background: var(--gold);
      color: var(--green-900);
      padding: 0.25rem 0.75rem;
      border-radius: 20px;
      font-size: 0.7rem;
      font-weight: 700;
      margin-top: 0.5rem;
    }

    /* Upcoming Bills */
    .bill-item {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0.85rem 0;
      border-bottom: 1px solid var(--border);
    }
    .bill-item:last-child { border-bottom: none; }
    .bill-left { display: flex; align-items: center; gap: 0.75rem; }
    .bill-icon {
      width: 36px; height: 36px;
      border-radius: 8px;
      display: flex; align-items: center; justify-content: center;
      font-size: 0.9rem;
    }
    .bill-icon.urgent { background: #fef2f2; }
    .bill-icon.normal { background: #fefce8; }
    .bill-name { font-weight: 600; font-size: 0.85rem; }
    .bill-due { font-size: 0.7rem; color: var(--text-secondary); }
    .bill-amount { font-weight: 700; font-size: 0.9rem; }

    /* Promo Card */
    .promo-card {
      background: linear-gradient(135deg, #fefce8, #fef9c3);
      border-radius: var(--radius);
      padding: 1.5rem;
      border: 1px solid #fde68a;
    }
    .promo-card h4 { font-size: 0.95rem; font-weight: 700; margin-bottom: 0.5rem; color: #92400e; }
    .promo-card p { font-size: 0.8rem; color: #a16207; margin-bottom: 1rem; line-height: 1.5; }
    .promo-btn {
      display: inline-block;
      padding: 0.5rem 1.25rem;
      background: #92400e;
      color: white;
      border-radius: 8px;
      font-size: 0.75rem;
      font-weight: 700;
      transition: 0.2s;
    }
    .promo-btn:hover { background: #78350f; transform: translateY(-1px); }

    /* =============================================
       MOBILE BOTTOM NAV
       ============================================= */
    .mobile-nav {
      display: none;
      position: fixed;
      bottom: 0; left: 0; right: 0;
      background: white;
      border-top: 1px solid var(--border);
      z-index: 100;
      padding: 0.5rem 0;
      padding-bottom: max(0.5rem, env(safe-area-inset-bottom));
      box-shadow: 0 -4px 20px rgba(0,0,0,0.06);
    }
    .mobile-nav-grid {
      display: grid;
      grid-template-columns: repeat(5, 1fr);
    }
    .mob-nav-item {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 0.2rem;
      padding: 0.5rem 0;
      font-size: 0.6rem;
      font-weight: 600;
      color: var(--text-secondary);
      cursor: pointer;
      transition: color 0.2s;
    }
    .mob-nav-item.active { color: var(--green-700); }
    .mob-nav-item .mob-icon { font-size: 1.25rem; }

    /* MOBILE OVERLAY */
    .sidebar-overlay {
      display: none;
      position: fixed;
      inset: 0;
      background: rgba(0,0,0,0.5);
      z-index: 99;
      opacity: 0;
      transition: opacity 0.3s;
    }
    .sidebar-overlay.show { display: block; opacity: 1; }

    /* =============================================
       RESPONSIVE
       ============================================= */
    @media (max-width: 1200px) {
      .kpi-grid { grid-template-columns: repeat(2, 1fr); }
      .actions-grid { grid-template-columns: repeat(3, 1fr); }
      .main-grid { grid-template-columns: 1fr; }
    }

    @media (max-width: 900px) {
      .sidebar { transform: translateX(-100%); }
      .sidebar.open { transform: translateX(0); }
      .main { margin-left: 0; }
      .hamburger { display: flex; }
      .content { padding: 1.25rem; padding-bottom: 5rem; }
      .topbar { padding: 0 1.25rem; }
      .mobile-nav { display: block; }
    }

    @media (max-width: 600px) {
      .kpi-grid { grid-template-columns: 1fr 1fr; gap: 0.75rem; }
      .kpi-card { padding: 1rem; }
      .kpi-value { font-size: 1.35rem; }
      .actions-grid { grid-template-columns: repeat(3, 1fr); gap: 0.75rem; }
      .action-item { padding: 1rem 0.5rem; }
      .action-icon { width: 42px; height: 42px; font-size: 1.1rem; }
      .account-grid { grid-template-columns: 1fr; }
      .acct-card { padding: 1rem; }
    }

    /* =============================================
       UTILITY / ANIMATIONS
       ============================================= */
    @keyframes fadeInUp {
      from { opacity: 0; transform: translateY(12px); }
      to { opacity: 1; transform: translateY(0); }
    }
    .animate { animation: fadeInUp 0.5s ease both; }
    .delay-1 { animation-delay: 0.05s; }
    .delay-2 { animation-delay: 0.1s; }
    .delay-3 { animation-delay: 0.15s; }
    .delay-4 { animation-delay: 0.2s; }
    .delay-5 { animation-delay: 0.25s; }

    .btn-text {
      font-size: 0.75rem;
      font-weight: 600;
      color: var(--green-700);
      display: inline-flex;
      align-items: center;
      gap: 0.25rem;
    }
    .btn-text:hover { color: var(--green-900); }

    .empty-state {
      text-align: center;
      padding: 3rem 1rem;
      color: var(--text-secondary);
    }
    .empty-state .icon { font-size: 2.5rem; margin-bottom: 0.75rem; }
    .empty-state p { font-size: 0.9rem; }

    /* =============================================
       FOOTER STYLES
       ============================================= */
    .dashboard-footer {
      background: white;
      border-top: 1px solid var(--border);
      padding: 2rem;
      margin-top: 3rem;
      text-align: center;
      color: var(--text-secondary);
      font-size: 0.85rem;
    }
    .footer-links {
      display: flex;
      justify-content: center;
      gap: 1.5rem;
      margin-bottom: 1rem;
      flex-wrap: wrap;
    }
    .footer-links a {
      color: var(--green-700);
      font-weight: 600;
      text-decoration: none;
    }
    .footer-links a:hover { color: var(--green-900); }
    .footer-copy { opacity: 0.7; }

    /* =============================================
       LIVE CHAT WIDGET STYLES
       ============================================= */
    .chat-widget-container {
      position: fixed;
      bottom: 30px;
      right: 30px;
      z-index: 1000;
      font-family: 'DM Sans', sans-serif;
    }

    .chat-button {
      width: 64px;
      height: 64px;
      border-radius: 50%;
      background: linear-gradient(135deg, var(--green-800), var(--green-700));
      color: white;
      border: none;
      box-shadow: 0 8px 20px rgba(20, 74, 37, 0.4);
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1.75rem;
      transition: transform 0.2s, box-shadow 0.2s;
      position: relative;
    }
    .chat-button:hover {
      transform: scale(1.1);
      box-shadow: 0 10px 25px rgba(20, 74, 37, 0.5);
    }
    .chat-tooltip {
      position: absolute;
      right: 75px;
      background: #1e293b;
      color: white;
      padding: 6px 12px;
      border-radius: 8px;
      font-size: 0.75rem;
      font-weight: 600;
      white-space: nowrap;
      opacity: 0;
      pointer-events: none;
      transition: opacity 0.2s;
    }
    .chat-button:hover .chat-tooltip { opacity: 1; }

    .chat-window {
      position: absolute;
      bottom: 80px;
      right: 0;
      width: 340px;
      background: white;
      border-radius: 16px;
      box-shadow: 0 15px 40px rgba(0,0,0,0.15);
      overflow: hidden;
      display: flex;
      flex-direction: column;
      border: 1px solid var(--border);
      animation: slideUp 0.3s ease;
    }
    @keyframes slideUp {
      from { opacity: 0; transform: translateY(20px); }
      to { opacity: 1; transform: translateY(0); }
    }
    .hidden { display: none !important; }

    .chat-header {
      background: linear-gradient(135deg, var(--green-900), var(--green-800));
      color: white;
      padding: 1rem;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }
    .chat-header-info { display: flex; align-items: center; gap: 0.75rem; }
    .agent-avatar { width: 32px; height: 32px; background: rgba(255,255,255,0.2); border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 1rem; }
    .agent-name { font-weight: 700; font-size: 0.9rem; }
    .agent-status { font-size: 0.7rem; opacity: 0.8; }
    .close-chat { background: none; border: none; color: rgba(255,255,255,0.7); font-size: 1.2rem; cursor: pointer; padding: 4px; }
    .close-chat:hover { color: white; }

    .chat-body {
      height: 300px;
      background: #f8fafc;
      padding: 1rem;
      overflow-y: auto;
      display: flex;
      flex-direction: column;
      gap: 0.75rem;
    }
    .message { display: flex; flex-direction: column; max-width: 85%; }
    .message.bot { align-self: flex-start; }
    .message.user { align-self: flex-end; }
    .message-bubble {
      padding: 0.75rem 1rem;
      border-radius: 12px;
      font-size: 0.85rem;
      line-height: 1.4;
    }
    .message.bot .message-bubble {
      background: white;
      border-bottom-left-radius: 2px;
      border: 1px solid var(--border);
    }
    .message.user .message-bubble {
      background: var(--green-800);
      color: white;
      border-bottom-right-radius: 2px;
    }

    .chat-footer {
      padding: 0.75rem;
      background: white;
      border-top: 1px solid var(--border);
      display: flex;
      gap: 0.5rem;
    }
    #chat-input {
      flex: 1;
      padding: 0.6rem;
      border: 1px solid var(--border);
      border-radius: 8px;
      font-size: 0.85rem;
      outline: none;
    }
    #chat-input:focus { border-color: var(--green-600); }
    .send-btn {
      width: 36px; height: 36px;
      background: var(--green-800);
      color: white;
      border: none;
      border-radius: 8px;
      cursor: pointer;
      display: flex; align-items: center; justify-content: center;
    }
    .send-btn:hover { background: var(--green-700); }

    @media (max-width: 600px) {
      .chat-widget-container { bottom: 80px; right: 15px; }
      .chat-window { width: calc(100vw - 30px); right: -15px; }
    }
  </style>
</head>
<body>

  <%
    /* === SAFE VARIABLES & HELPERS === */
    const safeUser = user || { firstName: 'Customer', lastName: '' };
    const fullName = (safeUser.firstName || '') + ' ' + (safeUser.lastName || '');
    const initials = ((safeUser.firstName || 'C')[0] + (safeUser.lastName || 'U')[0]).toUpperCase();
    const isAdmin = safeUser.isAdmin === 1;

    const totalBal = typeof totalBalance !== 'undefined' ? totalBalance : 
      (accounts || []).reduce((s, a) => s + (Number(a.balance) || 0), 0);
    const totalIn = typeof deposits !== 'undefined' ? deposits : 0;
    const totalOut = typeof withdrawals !== 'undefined' ? withdrawals : 0;
    const acctCount = (accounts || []).length;

    // FIX: Safe check for monthlyBars to prevent "ReferenceError"
    let bars = [];
    if (typeof monthlyBars !== 'undefined' && monthlyBars && monthlyBars.length > 0) {
      bars = monthlyBars;
    } else {
      bars = [
        { label: 'Oct', height: 35 }, { label: 'Nov', height: 50 },
        { label: 'Dec', height: 28 }, { label: 'Jan', height: 62 },
        { label: 'Feb', height: 45 }, { label: 'Mar', height: 78 }
      ];
    }

    function money(v) {
      return '$' + Number(v || 0).toLocaleString('en-US', { minimumFractionDigits: 2 });
    }

    function txIcon(tx) {
      const d = (tx.description || tx.type || '').toLowerCase();
      if (d.includes('deposit') || d.includes('payroll') || d.includes('salary')) return '↓';
      if (d.includes('transfer')) return '⇄';
      if (d.includes('loan') || d.includes('interest')) return '📋';
      if (d.includes('bill') || d.includes('payment')) return '📄';
      if (d.includes('fuel') || d.includes('gas')) return '⛽';
      if (d.includes('feed') || d.includes('seed')) return '🌾';
      return '•';
    }

    function txClass(tx) { return Number(tx.amount) >= 0 ? 'in' : 'out'; }
    function txAmountStr(tx) {
      const n = Number(tx.amount || 0);
      return (n >= 0 ? '+' : '-') + money(Math.abs(n));
    }
  %>

  <!-- SIDEBAR OVERLAY (Mobile) -->
  <div class="sidebar-overlay" id="sidebarOverlay" onclick="toggleSidebar()"></div>

  <!-- SIDEBAR -->
  <aside class="sidebar" id="sidebar">
    <div class="sidebar-brand">
      <h2>Agri<span>Bank</span></h2>
      <div class="sub">Texas Regional</div>
    </div>

    <nav class="sidebar-nav">
      <div class="nav-section">Main</div>
      <a href="/dashboard" class="nav-item active">
        <span class="icon">📊</span> Dashboard
      </a>
      <a href="/accounts" class="nav-item">
        <span class="icon">💳</span> Accounts
      </a>
      <a href="/transactions" class="nav-item">
        <span class="icon">📋</span> Transactions
      </a>
      <a href="/transfer" class="nav-item">
        <span class="icon">⇄</span> Transfer
      </a>

      <div class="nav-section">Services</div>
      <a href="/billpay" class="nav-item">
        <span class="icon">💸</span> Bill Pay
      </a>
      <a href="/deposits" class="nav-item">
        <span class="icon">📱</span> Deposits
      </a>
      <a href="/loans" class="nav-item">
        <span class="icon">🏦</span> Loans
      </a>

      <div class="nav-section">Account</div>
      <a href="/profile" class="nav-item">
        <span class="icon">👤</span> Profile
      </a>
      <a href="/notifications" class="nav-item">
        <span class="icon">🔔</span> Notifications
        <% if (notifications && notifications.filter(n => !n.isRead).length > 0) { %>
          <span class="badge-dot"></span>
        <% } %>
      </a>
      <% if (isAdmin) { %>
        <a href="/admin" class="nav-item">
          <span class="icon">⚙️</span> Admin Panel
        </a>
      <% } %>
    </nav>

    <div class="sidebar-footer">
      <a href="/logout" class="sidebar-user">
        <div class="avatar"><%= initials %></div>
        <div class="user-info">
          <div class="name"><%= safeUser.firstName %></div>
          <div class="role"><%= isAdmin ? 'Administrator' : 'Member' %></div>
        </div>
        <span style="margin-left:auto; opacity:0.5;">→</span>
      </a>
    </div>
  </aside>

  <!-- MAIN AREA -->
  <div class="main">

    <!-- TOP BAR -->
    <header class="topbar">
      <div class="topbar-left">
        <button class="hamburger" onclick="toggleSidebar()">☰</button>
        <div class="topbar-title">
          <h1>Dashboard</h1>
          <span class="date"><%= new Date().toLocaleDateString('en-US', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' }) %></span>
        </div>
      </div>
      <div class="topbar-right">
        <button class="topbar-btn" data-balance-toggle title="Toggle Balances">👁️</button>
        <a href="/notifications" class="topbar-btn">
          🔔
          <% if (notifications && notifications.filter(n => !n.isRead).length > 0) { %>
            <span class="notif-dot"></span>
          <% } %>
        </a>
        <a href="/profile" class="topbar-btn">👤</a>
      </div>
    </header>

    <!-- CONTENT -->
    <div class="content">

      <!-- KPI ROW -->
      <div class="kpi-grid">
        <div class="kpi-card primary animate delay-1">
          <div class="kpi-icon">💰</div>
          <div class="kpi-label">Total Balance</div>
          <div class="kpi-value" data-balance="<%= money(totalBal) %>"><%= money(totalBal) %></div>
          <div class="kpi-trend up">▲ <span style="font-weight:400;">vs last month</span></div>
        </div>
        <div class="kpi-card animate delay-2">
          <div class="kpi-icon">📈</div>
          <div class="kpi-label">Monthly Income</div>
          <div class="kpi-value" data-balance="<%= money(totalIn) %>"><%= money(totalIn) %></div>
          <div class="kpi-trend up">▲ 12.4%</div>
        </div>
        <div class="kpi-card animate delay-3">
          <div class="kpi-icon">📉</div>
          <div class="kpi-label">Monthly Expenses</div>
          <div class="kpi-value" data-balance="<%= money(totalOut) %>"><%= money(totalOut) %></div>
          <div class="kpi-trend down">▼ 4.1%</div>
        </div>
        <div class="kpi-card animate delay-4">
          <div class="kpi-icon">🏦</div>
          <div class="kpi-label">Active Accounts</div>
          <div class="kpi-value" data-balance="<%= acctCount %>"><%= acctCount %></div>
          <div class="kpi-trend" style="color:var(--text-secondary);"><span>All accounts active</span></div>
        </div>
      </div>

      <!-- QUICK ACTIONS -->
      <div class="actions-grid animate delay-5">
        <a href="/transfer" class="action-item">
          <div class="action-icon">⇄</div>
          <div class="action-label">Transfer</div>
        </a>
        <a href="/billpay" class="action-item">
          <div class="action-icon">💸</div>
          <div class="action-label">Pay Bills</div>
        </a>
        <a href="/deposits" class="action-item">
          <div class="action-icon">📱</div>
          <div class="action-label">Deposit</div>
        </a>
        <a href="/loans" class="action-item">
          <div class="action-icon">🏦</div>
          <div class="action-label">Loans</div>
        </a>
        <a href="/credit-cards" class="action-item">
          <div class="action-icon">💳</div>
          <div class="action-label">Credit Cards</div>
        </a>
      </div>

      <!-- MAIN 2-COL GRID -->
      <div class="main-grid">
        
        <!-- LEFT: ACCOUNTS + TRANSACTIONS -->
        <div>
          
          <!-- ACCOUNTS -->
          <div class="widget" style="margin-bottom:1.5rem;">
            <div class="widget-header">
              <h3>Accounts Overview</h3>
              <a href="/accounts" class="btn-text">View All →</a>
            </div>
            <div class="widget-body">
              <% if (accounts && accounts.length > 0) { %>
                <div class="account-grid">
                  <% accounts.forEach(acc => { %>
                    <div class="acct-card <%= acc.type %>">
                      <div class="acct-top">
                        <div class="acct-icon-wrap"><%= acc.icon || '🏦' %></div>
                        <span class="acct-status">Active</span>
                      </div>
                      <div class="acct-name"><%= acc.name %></div>
                      <div class="acct-number">****<%= acc.number || '0000' %></div>
                      <div class="acct-bal" data-balance="<%= money(acc.balance) %>"><%= money(acc.balance) %></div>
                      <div class="acct-bal-label">Available Balance</div>
                      <div class="acct-actions">
                        <a href="/transactions?accountId=<%= acc.id %>" class="acct-btn">History</a>
                        <a href="/transfer" class="acct-btn primary-btn">Transfer</a>
                      </div>
                    </div>
                  <% }) %>
                </div>
              <% } else { %>
                <div class="empty-state">
                  <div class="icon">🔍</div>
                  <p>No accounts found. Contact support.</p>
                </div>
              <% } %>
            </div>
          </div>

          <!-- RECENT TRANSACTIONS -->
          <div class="widget">
            <div class="widget-header">
              <h3>Recent Transactions</h3>
              <a href="/transactions" class="btn-text">View All →</a>
            </div>
            <div class="widget-body" style="padding: 0.75rem 1.5rem;">
              <div class="tx-list">
                <% if (transactions && transactions.length > 0) {
                     transactions.slice(0, 8).forEach(tx => { %>
                  <div class="tx-row">
                    <div class="tx-icon <%= txClass(tx.amount) %>"><%= txIcon(tx) %></div>
                    <div class="tx-details">
                      <div class="tx-name"><%= tx.description || tx.type %></div>
                      <div class="tx-meta"><%= tx.dateFormatted || 'Recent' %></div>
                    </div>
                    <div class="tx-amount <%= txClass(tx.amount) %>"><%= txAmountStr(tx) %></div>
                  </div>
                <% }) } else { %>
                  <div class="empty-state">
                    <p>No recent transactions.</p>
                  </div>
                <% } %>
              </div>
            </div>
          </div>

          <!-- CHART -->
          <div class="widget" style="margin-top:1.5rem;">
            <div class="widget-header">
              <h3>Monthly Activity</h3>
              <span style="font-size:0.75rem; color:var(--text-secondary);">Last 6 months</span>
            </div>
            <div class="widget-body">
              <div class="chart-wrap">
                <% bars.forEach(b => { %>
                  <div class="chart-bar-group">
                    <div class="chart-bar" data-height="<%= b.height %>%" style="height:0;"></div>
                    <div class="chart-month"><%= b.label %></div>
                  </div>
                <% }) %>
              </div>
            </div>
          </div>

        </div>

        <!-- RIGHT: SIDEBAR WIDGETS -->
        <div class="right-stack">
          
          <!-- CREDIT SCORE -->
          <div class="credit-score-card">
            <div class="credit-label">Credit Health</div>
            <div class="credit-ring">
              <span class="score">785</span>
            </div>
            <div class="credit-badge">Excellent</div>
            <div style="margin-top:0.75rem; font-size:0.75rem; opacity:0.7;">
              AgriBank Business Score
            </div>
            <a href="/profile" style="margin-top:0.75rem; display:inline-block; font-size:0.7rem; font-weight:600; opacity:0.8;">
              View Details →
            </a>
          </div>

          <!-- UPCOMING BILLS -->
          <div class="widget">
            <div class="widget-header">
              <h3>Upcoming Bills</h3>
            </div>
            <div class="widget-body" style="padding: 0.5rem 1.5rem;">
              <div class="bill-item">
                <div class="bill-left">
                  <div class="bill-icon urgent">🔴</div>
                  <div>
                    <div class="bill-name">Equipment Lease</div>
                    <div class="bill-due">Tomorrow</div>
                  </div>
                </div>
                <div class="bill-amount">$1,250.00</div>
              </div>
              <div class="bill-item">
                <div class="bill-left">
                  <div class="bill-icon normal">🟡</div>
                  <div>
                    <div class="bill-name">Farm Insurance</div>
                    <div class="bill-due">Apr 15</div>
                  </div>
                </div>
                <div class="bill-amount">$890.00</div>
              </div>
              <div class="bill-item">
                <div class="bill-left">
                  <div class="bill-icon normal">🟢</div>
                  <div>
                    <div class="bill-name">Property Tax</div>
                    <div class="bill-due">May 1</div>
                  </div>
                </div>
                <div class="bill-amount">$2,100.00</div>
              </div>
              <a href="/billpay" class="acct-btn primary-btn" style="display:block; margin-top:0.75rem; text-align:center; text-decoration:none;">
                Pay All Now
              </a>
            </div>
          </div>

          <!-- PROMO -->
          <div class="promo-card">
            <h4>🌱 AgriRewards Credit Card</h4>
            <p>Earn 3% cash back on feed, seed, and agricultural supplies. No annual fee for the first year.</p>
            <a href="/credit-cards" class="promo-btn">Apply Now</a>
          </div>

        </div>
      </div>

      <!-- PROFESSIONAL FOOTER -->
      <footer class="dashboard-footer">
        <div class="footer-links">
          <a href="/about">About AgriBank</a>
          <a href="/privacy">Privacy Policy</a>
          <a href="/terms">Terms of Service</a>
          <a href="/security">Security Center</a>
          <a href="/help">Help & Support</a>
        </div>
        <div class="footer-copy">
          © <%= new Date().getFullYear() %> AgriBank Texas Regional. All rights reserved. Member FDIC. Equal Housing Lender.
        </div>
      </footer>

    </div>
  </div>

  <!-- MOBILE BOTTOM NAV -->
  <nav class="mobile-nav">
    <div class="mobile-nav-grid">
      <a href="/dashboard" class="mob-nav-item active">
        <span class="mob-icon">📊</span>
        Home
      </a>
      <a href="/accounts" class="mob-nav-item">
        <span class="mob-icon">💳</span>
        Accounts
      </a>
      <a href="/transfer" class="mob-nav-item">
        <span class="mob-icon">⇄</span>
        Transfer
      </a>
      <a href="/billpay" class="mob-nav-item">
        <span class="mob-icon">💸</span>
        Pay
      </a>
      <a href="/profile" class="mob-nav-item">
        <span class="mob-icon">👤</span>
        Profile
      </a>
    </div>
  </nav>

  <!-- LIVE CHAT WIDGET -->
  <div class="chat-widget-container">
    <!-- Chat Window -->
    <div id="chat-window" class="chat-window hidden">
      <div class="chat-header">
        <div class="chat-header-info">
          <div class="agent-avatar">🌾</div>
          <div>
            <div class="agent-name">AgriBank Support</div>
            <div class="agent-status">● Online</div>
          </div>
        </div>
        <button class="close-chat" onclick="toggleChat()">✕</button>
      </div>
      <div class="chat-body" id="chat-body">
        <div class="message bot">
          <div class="message-bubble">Howdy! 👋 I'm here to help with your AgriBank account. How can I assist you today?</div>
        </div>
      </div>
      <div class="chat-footer">
        <input type="text" id="chat-input" placeholder="Type a message..." onkeypress="handleEnter(event)">
        <button class="send-btn" onclick="sendMessage()">➤</button>
      </div>
    </div>
    <!-- Floating Button -->
    <button class="chat-button" onclick="toggleChat()">
      <span class="chat-icon">💬</span>
      <span class="chat-tooltip">Live Support</span>
    </button>
  </div>

  <!-- SCRIPTS -->
  <script>
    /* Sidebar Toggle */
    function toggleSidebar() {
      const sidebar = document.getElementById('sidebar');
      const overlay = document.getElementById('sidebarOverlay');
      sidebar.classList.toggle('open');
      overlay.classList.toggle('show');
    }

    /* Balance Toggle */
    document.addEventListener('DOMContentLoaded', () => {
      // Animate chart bars
      setTimeout(() => {
        document.querySelectorAll('.chart-bar').forEach(el => {
          el.style.height = el.getAttribute('data-height');
        });
      }, 300);

      // Balance visibility
      const toggleBtn = document.querySelector('[data-balance-toggle]');
      const balances = document.querySelectorAll('[data-balance]');
      let hidden = false;

      if (toggleBtn && balances.length) {
        toggleBtn.addEventListener('click', () => {
          hidden = !hidden;
          toggleBtn.textContent = hidden ? '🙈' : '👁️';
          balances.forEach(el => {
            el.textContent = hidden ? '••••••' : el.getAttribute('data-balance');
          });
        });
      }
    });

    /* Live Chat Logic */
    function toggleChat() {
      const chatWindow = document.getElementById('chat-window');
      chatWindow.classList.toggle('hidden');
      if (!chatWindow.classList.contains('hidden')) {
        setTimeout(() => document.getElementById('chat-input').focus(), 100);
      }
    }

    function handleEnter(e) {
      if (e.key === 'Enter') sendMessage();
    }

    function sendMessage() {
      const input = document.getElementById('chat-input');
      const text = input.value.trim();
      if (!text) return;

      const body = document.getElementById('chat-body');
      const userMsg = document.createElement('div');
      userMsg.className = 'message user';
      userMsg.innerHTML = `<div class="message-bubble">${text}</div>`;
      body.appendChild(userMsg);
      input.value = '';
      body.scrollTop = body.scrollHeight;

      setTimeout(() => {
        const responses = [
          "Thanks for reaching out! A support agent will be with you shortly.",
          "I can help with that. Could you provide your account number?",
          "We're currently experiencing high volume, but you are next in line!"
        ];
        const botMsg = document.createElement('div');
        botMsg.className = 'message bot';
        botMsg.innerHTML = `<div class="message-bubble">${responses[Math.floor(Math.random() * responses.length)]}</div>`;
        body.appendChild(botMsg);
        body.scrollTop = body.scrollHeight;
      }, 1000);
    }
  </script>

</body>
</html>

