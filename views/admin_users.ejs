<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <title>Admin – Users</title>
  <style>
    body { font-family: system-ui, -apple-system, "Segoe UI", Roboto, Arial; padding:20px; }
    table { width:100%; border-collapse:collapse; margin-top:12px; }
    th, td { padding:8px 12px; border-bottom:1px solid #ddd; }
    input { padding:6px; }
  </style>
</head>
<body>
  <h1>Admin – Users</h1>
  <p>Logged in as <strong><%= user.username %></strong> | <a href="/admin/export/users">Export All (CSV)</a></p>

  <form method="GET" action="/admin/users">
    <input type="text" name="q" placeholder="Search username or email" value="<%= query %>"/>
    <button type="submit">Search</button>
  </form>

  <table>
    <thead><tr><th>ID</th><th>Username</th><th>Email</th><th>Admin?</th><th>Locked?</th><th>Created</th><th>Actions</th></tr></thead>
    <tbody>
      <% users.forEach(u => { %>
        <tr>
          <td><%= u.id %></td>
          <td><%= u.username %></td>
          <td><%= u.email %></td>
          <td><%= u.isAdmin === 1 ? 'Yes' : 'No' %></td>
          <td><%= u.isLocked === 1 ? 'Yes' : 'No' %></td>
          <td><%= new Date(u.created_at).toLocaleString() %></td>
          <td><a href="/admin/users/<%= u.id %>">View</a></td>
        </tr>
      <% }) %>
    </tbody>
  </table>

  <p><a href="/admin">Back to Dashboard</a> | <a href="/logout">Logout</a></p>
</body>
</html>