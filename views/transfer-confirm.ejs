<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('partials/head', { title: 'Transfer Confirmed | AgriBank Texas' }) %>
  <style>
    :root {
      --navy: #0a1c14; --green-900: #0f2b1f; --green-800: #144a25;
      --green-700: #1a5c30; --green-600: #22753d; --gold: #d4a047;
      --bg: #f0f2f5; --surface: #ffffff; --text: #0f172a;
      --text-secondary: #64748b; --border: #e2e8f0;
      --success: #10b981; --danger: #ef4444;
      --sidebar-w: 260px; --header-h: 72px; --radius: 16px; --radius-sm: 10px;
      --shadow: 0 1px 3px rgba(0,0,0,0.06), 0 4px 12px rgba(0,0,0,0.04);
      --shadow-lg: 0 8px 30px rgba(0,0,0,0.08);
    }
    * { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }
    body { font-family: 'DM Sans', -apple-system, sans-serif; background: var(--bg); color: var(--text); line-height: 1.5; -webkit-font-smoothing: antialiased; min-height: 100vh; display: flex; flex-direction: column; }
    a { text-decoration: none; color: inherit; transition: 0.2s; }

    /* SIDEBAR */
    .sidebar { position: fixed; top: 0; left: 0; width: var(--sidebar-w); height: 100vh; background: var(--green-900); color: white; z-index: 100; display: flex; flex-direction: column; transition: transform 0.3s ease; overflow-y: auto; }
    .sidebar-brand { padding: 1.75rem 1.5rem; border-bottom: 1px solid rgba(255,255,255,0.08); }
    .sidebar-brand h2 { font-family: 'DM Serif Display', serif; font-size: 1.35rem; }
    .sidebar-brand span { color: var(--gold); }
    .sidebar-brand .sub { font-size: 0.65rem; text-transform: uppercase; letter-spacing: 1.5px; opacity: 0.5; margin-top: 0.25rem; font-weight: 600; }
    .sidebar-nav { padding: 1.25rem 1rem; flex: 1; }
    .nav-section { font-size: 0.6rem; text-transform: uppercase; letter-spacing: 1.5px; opacity: 0.35; padding: 0.75rem 0.75rem 0.4rem; font-weight: 700; }
    .nav-item { display: flex; align-items: center; gap: 0.75rem; padding: 0.7rem 0.85rem; border-radius: var(--radius-sm); font-size: 0.875rem; font-weight: 500; color: rgba(255,255,255,0.65); margin-bottom: 2px; cursor: pointer; }
    .nav-item:hover { background: rgba(255,255,255,0.08); color: white; }
    .nav-item.active { background: rgba(212, 160, 71, 0.15); color: var(--gold); font-weight: 600; }
    .nav-item .icon { width: 20px; text-align: center; font-size: 1rem; opacity: 0.85; }
    .sidebar-footer { padding: 1.25rem; border-top: 1px solid rgba(255,255,255,0.08); }
    .sidebar-user { display: flex; align-items: center; gap: 0.75rem; padding: 0.5rem; border-radius: var(--radius-sm); cursor: pointer; }
    .sidebar-user:hover { background: rgba(255,255,255,0.05); }
    .avatar { width: 36px; height: 36px; border-radius: 50%; background: var(--gold); display: flex; align-items: center; justify-content: center; font-weight: 700; font-size: 0.85rem; color: var(--green-900); }
    .user-info .name { font-size: 0.85rem; font-weight: 600; }
    .user-info .role { font-size: 0.7rem; opacity: 0.5; }

    /* MAIN */
    .main { margin-left: var(--sidebar-w); min-height: 100vh; flex: 1; display: flex; flex-direction: column; }
    .topbar { position: sticky; top: 0; height: var(--header-h); background: rgba(255,255,255,0.85); backdrop-filter: blur(20px); border-bottom: 1px solid var(--border); display: flex; align-items: center; justify-content: space-between; padding: 0 2rem; z-index: 50; }
    .topbar-left { display: flex; align-items: center; gap: 1rem; }
    .hamburger { display: none; background: none; border: none; font-size: 1.5rem; cursor: pointer; color: var(--text); }
    .topbar-title h1 { font-size: 1.15rem; font-weight: 700; }
    .topbar-right { display: flex; align-items: center; gap: 0.75rem; }
    .topbar-btn { width: 40px; height: 40px; border-radius: 50%; background: transparent; border: 1px solid var(--border); display: flex; align-items: center; justify-content: center; font-size: 1.1rem; cursor: pointer; transition: 0.2s; }
    .topbar-btn:hover { background: #f8fafc; border-color: #cbd5e1; }
    
    .content { padding: 2rem; max-width: 800px; margin: 0 auto; width: 100%; flex: 1; display: flex; align-items: center; justify-content: center; }

    /* CONFIRMATION CARD */
    .confirm-card {
      background: var(--surface);
      border-radius: var(--radius);
      box-shadow: var(--shadow-lg);
      width: 100%;
      overflow: hidden;
      border: 1px solid var(--border);
      animation: slideUp 0.5s cubic-bezier(0.16, 1, 0.3, 1);
    }

    @keyframes slideUp {
      from { opacity: 0; transform: translateY(20px); }
      to { opacity: 1; transform: translateY(0); }
    }

    .confirm-header {
      background: linear-gradient(135deg, var(--green-800), var(--green-700));
      color: white;
      padding: 3rem 2rem;
      text-align: center;
      position: relative;
    }
    
    .success-icon {
      width: 80px; height: 80px;
      background: white;
      border-radius: 50%;
      display: flex; align-items: center; justify-content: center;
      margin: 0 auto 1.5rem;
      box-shadow: 0 8px 20px rgba(0,0,0,0.2);
      font-size: 2.5rem;
      animation: scaleIn 0.4s cubic-bezier(0.34, 1.56, 0.64, 1) 0.2s both;
    }
    
    @keyframes scaleIn {
      from { transform: scale(0); }
      to { transform: scale(1); }
    }

    .confirm-header h2 { font-size: 1.5rem; font-weight: 700; margin-bottom: 0.5rem; }
    .confirm-header p { opacity: 0.85; font-size: 0.95rem; }

    .confirm-body { padding: 2rem; }

    .amount-display { text-align: center; margin-bottom: 2rem; }
    .amount-val { font-size: 2.5rem; font-weight: 800; font-family: 'DM Serif Display', serif; color: var(--success); }
    .amount-label { font-size: 0.8rem; color: var(--text-secondary); text-transform: uppercase; letter-spacing: 1px; margin-top: 0.25rem; }

    .details-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; margin-bottom: 2rem; padding-bottom: 2rem; border-bottom: 1px solid var(--border); }
    .detail-item .label { font-size: 0.7rem; font-weight: 700; text-transform: uppercase; color: var(--text-secondary); letter-spacing: 0.5px; margin-bottom: 0.4rem; }
    .detail-item .value { font-size: 0.95rem; font-weight: 600; color: var(--text); }
    .detail-item .value.mono { font-family: 'JetBrains Mono', monospace; font-size: 0.85rem; background: #f8fafc; padding: 0.25rem 0.5rem; border-radius: 4px; display: inline-block; }

    .arrival-box {
      background: #fefce8; border: 1px solid #fde68a; border-radius: 10px; padding: 1rem; text-align: center; margin-bottom: 2rem;
    }
    .arrival-box .label { font-size: 0.7rem; font-weight: 700; color: #92400e; text-transform: uppercase; margin-bottom: 0.25rem; }
    .arrival-box .time { font-family: 'DM Serif Display', serif; font-size: 1.1rem; font-weight: 700; color: #854d0e; }
    .arrival-box .note { font-size: 0.7rem; color: #a16207; margin-top: 0.25rem; }

    .actions { display: flex; gap: 1rem; }
    .btn {
      flex: 1; padding: 0.85rem; border-radius: 8px; font-size: 0.9rem; font-weight: 600; text-align: center;
      cursor: pointer; transition: all 0.2s; display: flex; align-items: center; justify-content: center; gap: 0.5rem; border: none;
    }
    .btn-primary { background: var(--green-800); color: white; }
    .btn-primary:hover { background: var(--green-700); }
    .btn-secondary { background: #f8fafc; color: var(--text); border: 1px solid var(--border); }
    .btn-secondary:hover { background: #f1f5f9; border-color: #cbd5e1; }

    /* MOBILE */
    .sidebar-overlay { display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.5); z-index: 99; opacity: 0; transition: opacity 0.3s; }
    .sidebar-overlay.show { display: block; opacity: 1; }
    .mobile-nav { display: none; position: fixed; bottom: 0; left: 0; right: 0; background: white; border-top: 1px solid var(--border); z-index: 100; padding: 0.5rem 0; padding-bottom: max(0.5rem, env(safe-area-inset-bottom)); box-shadow: 0 -4px 20px rgba(0,0,0,0.06); }
    .mobile-nav-grid { display: grid; grid-template-columns: repeat(5, 1fr); }
    .mob-nav-item { display: flex; flex-direction: column; align-items: center; gap: 0.2rem; padding: 0.5rem 0; font-size: 0.6rem; font-weight: 600; color: var(--text-secondary); cursor: pointer; }
    .mob-nav-item.active { color: var(--green-700); }
    .mob-nav-item .mob-icon { font-size: 1.25rem; }

    @media (max-width: 900px) {
      .sidebar { transform: translateX(-100%); }
      .sidebar.open { transform: translateX(0); }
      .main { margin-left: 0; }
      .hamburger { display: flex; }
      .content { padding: 1.25rem 1rem; padding-bottom: 5rem; }
      .topbar { padding: 0 1.25rem; }
      .mobile-nav { display: block; }
      .confirm-card { box-shadow: none; border: none; background: transparent; }
      .confirm-header { border-radius: var(--radius); margin-bottom: 1.5rem; }
      .confirm-body { background: var(--surface); border-radius: var(--radius); padding: 1.5rem; box-shadow: var(--shadow); }
      .details-grid { grid-template-columns: 1fr; gap: 1rem; }
      .actions { flex-direction: column; }
    }

    .btn-text { font-size: 0.75rem; font-weight: 600; color: var(--green-700); display: inline-flex; align-items: center; gap: 0.25rem; cursor: pointer; margin-bottom: 1rem; }
    .btn-text:hover { color: var(--green-900); }
  </style>
</head>
<body>
  <%
    /* 
       FIX: 
       1. Use a temporary variable (_data) to hold the summary object.
       2. Use distinct names (val_amount, etc.) for the output variables.
       3. This prevents "Cannot access 'memo' before initialization" (TDZ error).
    */
    var _data = (typeof summary !== 'undefined' && summary) ? summary : {};
    
    var val_amount = _data.amount || '$0.00';
    var val_type = _data.transferType || 'Transfer';
    var val_from = _data.fromAccount || 'Account';
    var val_to = _data.toAccount || 'Account';
    var val_date = _data.date || new Date().toLocaleString();
    var val_memo = _data.memo || null;
    
    var safeUser = (typeof user !== 'undefined' && user) ? user : { firstName: 'Customer' };
    var initials = ((safeUser.firstName || 'C')[0]).toUpperCase();

    // Dynamic arrival estimate
    var arrivalDays = 'Instant';
    var arrivalNote = 'Funds available immediately';
    if(val_type.includes('International')) { arrivalDays = '3-5 Business Days'; arrivalNote = 'Depends on recipient bank processing'; }
    else if(val_type.includes('Wire')) { arrivalDays = 'Same Day'; arrivalNote = 'If submitted before 4:00 PM CT'; }
    else if(val_type.includes('External')) { arrivalDays = '1-2 Business Days'; arrivalNote = 'Standard ACH processing time'; }
  %>

  <div class="sidebar-overlay" id="sidebarOverlay" onclick="toggleSidebar()"></div>
  <aside class="sidebar" id="sidebar">
    <div class="sidebar-brand"><h2>Agri<span>Bank</span></h2><div class="sub">Texas Regional</div></div>
    <nav class="sidebar-nav">
      <div class="nav-section">Main</div>
      <a href="/dashboard" class="nav-item"><span class="icon">📊</span> Dashboard</a>
      <a href="/accounts" class="nav-item"><span class="icon">💳</span> Accounts</a>
      <a href="/transactions" class="nav-item"><span class="icon">📋</span> Transactions</a>
      <a href="/transfer" class="nav-item active"><span class="icon">⇄</span> Transfer</a>
      <div class="nav-section">Services</div>
      <a href="/billpay" class="nav-item"><span class="icon">💸</span> Bill Pay</a>
      <a href="/deposits" class="nav-item"><span class="icon">📱</span> Deposits</a>
      <a href="/loans" class="nav-item"><span class="icon">🏦</span> Loans</a>
      <div class="nav-section">Account</div>
      <a href="/profile" class="nav-item"><span class="icon">👤</span> Profile</a>
      <a href="/notifications" class="nav-item"><span class="icon">🔔</span> Notifications</a>
    </nav>
    <div class="sidebar-footer">
      <a href="/logout" class="sidebar-user">
        <div class="avatar"><%= initials %></div>
        <div class="user-info"><div class="name"><%= safeUser.firstName %></div><div class="role">Member</div></div>
      </a>
    </div>
  </aside>

  <div class="main">
    <header class="topbar">
      <div class="topbar-left">
        <button class="hamburger" onclick="toggleSidebar()">☰</button>
        <div class="topbar-title"><h1>Transfer Confirmation</h1></div>
      </div>
      <div class="topbar-right">
        <a href="/notifications" class="topbar-btn">🔔</a>
        <a href="/profile" class="topbar-btn">👤</a>
      </div>
    </header>

    <div class="content">
      <div style="width:100%;">
        <a href="/transfer" class="btn-text">← Make Another Transfer</a>
        
        <div class="confirm-card">
          <div class="confirm-header">
            <div class="success-icon">✓</div>
            <h2>Transfer Successful</h2>
            <p>Your funds have been sent securely.</p>
          </div>

          <div class="confirm-body">
            <div class="amount-display">
              <div class="amount-val"><%= val_amount %></div>
              <div class="amount-label"><%= val_type %></div>
            </div>

            <div class="details-grid">
              <div class="detail-item">
                <div class="label">From Account</div>
                <div class="value mono"><%= val_from %></div>
              </div>
              <div class="detail-item">
                <div class="label">To Account</div>
                <div class="value mono"><%= val_to %></div>
              </div>
              <div class="detail-item">
                <div class="label">Date & Time</div>
                <div class="value"><%= val_date %></div>
              </div>
              <% if (val_memo) { %>
              <div class="detail-item">
                <div class="label">Memo</div>
                <div class="value"><%= val_memo %></div>
              </div>
              <% } %>
            </div>

            <div class="arrival-box">
              <div class="label">Expected Arrival</div>
              <div class="time"><%= arrivalDays %></div>
              <div class="note"><%= arrivalNote %></div>
            </div>

            <div class="actions">
              <a href="/dashboard" class="btn btn-primary">Return to Dashboard</a>
              <a href="/transactions" class="btn btn-secondary">View Transactions</a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <nav class="mobile-nav">
    <div class="mobile-nav-grid">
      <a href="/dashboard" class="mob-nav-item active"><span class="mob-icon">📊</span>Home</a>
      <a href="/accounts" class="mob-nav-item"><span class="mob-icon">💳</span>Accounts</a>
      <a href="/transfer" class="mob-nav-item"><span class="mob-icon">⇄</span>Transfer</a>
      <a href="/billpay" class="mob-nav-item"><span class="mob-icon">💸</span>Pay</a>
      <a href="/profile" class="mob-nav-item"><span class="mob-icon">👤</span>Profile</a>
    </div>
  </nav>

  <script>
    function toggleSidebar() {
      document.getElementById('sidebar').classList.toggle('open');
      document.getElementById('sidebarOverlay').classList.toggle('show');
    }
  </script>
</body>
</html>