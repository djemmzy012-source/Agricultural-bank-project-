<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
 <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">  <title>Bill Pay History</title>
  <style>
    body { font-family: system-ui, -apple-system, "Segoe UI", Roboto, Arial; padding: 20px; }
    table { width: 100%; border-collapse: collapse; }
    th, td { padding: 8px 12px; border-bottom: 1px solid #ddd; }
  </style>
</head>
<body>
  <h1>Bill Pay History</h1>
  <p>
    <a href="/billpay" title="Back to Bill Pay">Back to Bill Pay</a> |
    <a href="/billpay/history/export" title="Export Bill Pay History (CSV)">Export CSV</a>
  </p>

  <table>
    <thead>
      <tr><th>Date</th><th>From</th><th>Amount</th><th>Payee</th></tr>
    </thead>
    <tbody>
      <% transactions.forEach(t => { %>
        <tr>
          <td><%= new Date(t.date).toLocaleString() %></td>
          <td><%= t.fromAccount %></td>
          <td>$<%= Number(t.amount).toFixed(2) %></td>
          <td><%= t.payeeName %></td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</body>
</html>