<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('partials/head', { title: 'Bill Pay History | AgriBank Texas' }) %>
  <style>
    :root {
      --navy: #0a1c14; --green-900: #0f2b1f; --green-800: #144a25;
      --green-700: #1a5c30; --green-600: #22753d; --gold: #d4a047;
      --bg: #f0f2f5; --surface: #ffffff; --text: #0f172a;
      --text-secondary: #64748b; --border: #e2e8f0;
      --success: #10b981; --danger: #ef4444;
      --sidebar-w: 260px; --header-h: 72px; --radius: 16px; --radius-sm: 10px;
      --shadow: 0 1px 3px rgba(0,0,0,0.06), 0 4px 12px rgba(0,0,0,0.04);
    }
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: 'DM Sans', sans-serif; background: var(--bg); color: var(--text); line-height: 1.5; }
    a { text-decoration: none; color: inherit; }

    /* SIDEBAR (Standardized) */
    .sidebar { position: fixed; top: 0; left: 0; width: var(--sidebar-w); height: 100vh; background: var(--green-900); color: white; z-index: 100; display: flex; flex-direction: column; }
    .sidebar-brand { padding: 1.5rem; border-bottom: 1px solid rgba(255,255,255,0.1); font-family: 'DM Serif Display', serif; font-size: 1.5rem; }
    .sidebar-brand span { color: var(--gold); }
    .sidebar-nav { padding: 1rem; flex: 1; }
    .nav-item { display: flex; align-items: center; gap: 0.75rem; padding: 0.75rem; border-radius: 8px; color: rgba(255,255,255,0.7); margin-bottom: 0.25rem; }
    .nav-item:hover { background: rgba(255,255,255,0.1); color: white; }
    .nav-item.active { background: rgba(212, 160, 71, 0.2); color: var(--gold); font-weight: 600; }

    /* MAIN */
    .main { margin-left: var(--sidebar-w); min-height: 100vh; }
    .topbar { height: 70px; background: white; border-bottom: 1px solid var(--border); display: flex; align-items: center; padding: 0 2rem; justify-content: space-between; position: sticky; top: 0; z-index: 50; }
    .content { padding: 2rem; max-width: 1200px; margin: 0 auto; }

    /* HISTORY STYLES */
    .action-bar { display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem; flex-wrap: wrap; gap: 1rem; }
    .page-title { font-size: 1.5rem; font-weight: 700; color: var(--navy); }
    
    .btn { padding: 0.6rem 1.2rem; border-radius: 8px; font-weight: 600; font-size: 0.9rem; text-decoration: none; display: inline-flex; align-items: center; gap: 0.5rem; transition: 0.2s; }
    .btn-secondary { background: white; border: 1px solid var(--border); color: var(--text); }
    .btn-secondary:hover { background: #f8fafc; border-color: #cbd5e1; }
    
    .card { background: white; border-radius: 12px; box-shadow: var(--shadow); overflow: hidden; }
    .table-container { overflow-x: auto; }
    table { width: 100%; border-collapse: collapse; min-width: 600px; }
    th { background: #f8fafc; text-align: left; font-weight: 600; color: var(--text-secondary); font-size: 0.75rem; text-transform: uppercase; padding: 1rem; letter-spacing: 0.5px; }
    td { padding: 1rem; border-top: 1px solid var(--border); font-size: 0.9rem; vertical-align: middle; }
    tr:hover { background: #f8fafc; }
    
    .payee-cell { font-weight: 600; color: var(--text); }
    .account-cell { color: var(--text-secondary); font-size: 0.8rem; display: block; }
    .amount-cell { font-family: 'DM Serif Display', serif; font-size: 1.1rem; font-weight: 700; color: var(--text); }
    .date-cell { color: var(--text-secondary); font-size: 0.85rem; }

    .empty-state { padding: 3rem; text-align: center; color: var(--text-secondary); }
    .empty-icon { font-size: 3rem; margin-bottom: 1rem; opacity: 0.5; }

    /* MOBILE */
    @media (max-width: 768px) {
      .sidebar { display: none; }
      .main { margin-left: 0; }
      .content { padding: 1rem; }
      .action-bar { flex-direction: column; align-items: flex-start; }
      .btn { width: 100%; justify-content: center; }
    }
  </style>
</head>
<body>
  <% var currentUser = user || { firstName: 'User' }; %>

  <aside class="sidebar">
    <div class="sidebar-brand">Agri<span>Bank</span></div>
    <nav class="sidebar-nav">
      <a href="/dashboard" class="nav-item"><span class="icon">📊</span> Dashboard</a>
      <a href="/accounts" class="nav-item"><span class="icon">💳</span> Accounts</a>
      <a href="/transactions" class="nav-item"><span class="icon">📋</span> Transactions</a>
      <a href="/transfer" class="nav-item"><span class="icon">⇄</span> Transfer</a>
      <a href="/billpay" class="nav-item"><span class="icon">💸</span> Bill Pay</a>
      <a href="/billpay/history" class="nav-item active"><span class="icon">📜</span> History</a>
      <a href="/loans" class="nav-item"><span class="icon">🏦</span> Loans</a>
      <a href="/profile" class="nav-item"><span class="icon">👤</span> Profile</a>
      <a href="/logout" class="nav-item"><span class="icon">🚪</span> Logout</a>
    </nav>
  </aside>

  <div class="main">
    <header class="topbar">
      <h3>Bill Pay History</h3>
      <span>Welcome, <%= currentUser.firstName %></span>
    </header>

    <div class="content">
      
      <div class="action-bar">
        <h1 class="page-title">Transaction History</h1>
        <div style="display: flex; gap: 0.5rem; width: 100%; max-width: 300px;">
          <a href="/billpay" class="btn btn-secondary" style="flex:1;">← Back to Pay</a>
          <a href="/billpay/history/export" class="btn btn-secondary" style="flex:1;">⬇️ Export</a>
        </div>
      </div>

      <div class="card">
        <% if (typeof transactions !== 'undefined' && transactions.length > 0) { %>
          <div class="table-container">
            <table>
              <thead>
                <tr>
                  <th>Date</th>
                  <th>Payee</th>
                  <th>From Account</th>
                  <th style="text-align: right;">Amount</th>
                </tr>
              </thead>
              <tbody>
                <% transactions.forEach(function(t) { %>
                  <tr>
                    <td class="date-cell"><%= new Date(t.date).toLocaleDateString() %></td>
                    <td>
                      <div class="payee-cell"><%= t.payeeName || 'Unknown Payee' %></div>
                      <span class="account-cell">Ref: <%= t.accountNumber || '—' %></span>
                    </td>
                    <td>
                      <span class="payee-cell"><%= t.fromAccount || 'Checking' %></span>
                      <span class="account-cell">****<%= t.accountNumber ? t.accountNumber.toString().slice(-4) : '0000' %></span>
                    </td>
                    <td style="text-align: right;">
                      <span class="amount-cell">-$<%= Number(t.amount).toFixed(2) %></span>
                    </td>
                  </tr>
                <% }); %>
              </tbody>
            </table>
          </div>
        <% } else { %>
          <div class="empty-state">
            <div class="empty-icon">📭</div>
            <h3>No History Found</h3>
            <p>You haven't made any bill payments yet.</p>
            <a href="/billpay" class="btn" style="background:var(--green-800); color:white; margin-top:1rem; display:inline-flex;">Make a Payment</a>
          </div>
        <% } %>
      </div>

    </div>
  </div>
</body>
</html>

