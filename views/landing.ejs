<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('partials/head', { title: 'AgriBank Texas | Grow Your Future' }) %>
  <style>
    :root {
      --navy: #0a1c14;
      --green-dark: #0f2b1f;
      --green-main: #144a25;
      --green-mid: #1a5c30;
      --green-light: #22753d;
      --gold: #c8a045;
      --gold-light: #d4af52;
      --bg-white: #ffffff;
      --bg-offwhite: #f8faf9;
      --bg-gray: #f1f5f3;
      --text-primary: #0f172a;
      --text-secondary: #475569;
      --text-muted: #64748b;
      --border: #e2e8f0;
      --radius-sm: 8px;
      --radius-md: 12px;
      --radius-lg: 16px;
      --shadow-sm: 0 1px 3px rgba(0,0,0,0.05);
      --shadow-md: 0 4px 12px rgba(0,0,0,0.06);
      --shadow-lg: 0 8px 24px rgba(0,0,0,0.08);
      --transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
    }

    * { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }
    body {
      font-family: 'DM Sans', -apple-system, BlinkMacSystemFont, sans-serif;
      background: var(--bg-white);
      color: var(--text-primary);
      line-height: 1.65;
      -webkit-font-smoothing: antialiased;
      overflow-x: hidden;
    }
    a { text-decoration: none; color: inherit; transition: var(--transition); }
    ul { list-style: none; }

    /* ==================== UTILITIES ==================== */
    .container { max-width: 1240px; margin: 0 auto; padding: 0 1.5rem; }
    .section { padding: 5rem 0; }
    .section-header { text-align: center; margin-bottom: 3.5rem; }
    .section-tag {
      display: inline-block; font-size: 0.7rem; font-weight: 700;
      text-transform: uppercase; letter-spacing: 1.5px; color: var(--gold);
      margin-bottom: 0.75rem;
    }
    .section-title {
      font-family: 'DM Serif Display', serif; font-size: clamp(1.8rem, 3vw, 2.4rem);
      color: var(--navy); margin-bottom: 0.75rem; line-height: 1.2;
    }
    .section-desc { font-size: 1.05rem; color: var(--text-secondary); max-width: 580px; margin: 0 auto; }

    /* ==================== BUTTONS ==================== */
    .btn {
      display: inline-flex; align-items: center; justify-content: center; gap: 0.5rem;
      padding: 0.75rem 1.5rem; border-radius: var(--radius-sm);
      font-weight: 600; font-size: 0.9rem; cursor: pointer; border: none;
      transition: var(--transition); font-family: inherit;
    }
    .btn-primary { background: var(--gold); color: var(--navy); }
    .btn-primary:hover { background: var(--gold-light); transform: translateY(-2px); box-shadow: 0 4px 15px rgba(200,160,69,0.35); }
    .btn-outline { background: transparent; border: 2px solid var(--green-main); color: var(--green-main); }
    .btn-outline:hover { background: var(--green-main); color: white; }
    .btn-white { background: white; color: var(--navy); }
    .btn-white:hover { background: var(--bg-offwhite); transform: translateY(-2px); }
    .btn-ghost { background: transparent; color: var(--text-secondary); }
    .btn-ghost:hover { color: var(--navy); background: var(--bg-offwhite); }

    /* ==================== TOP BAR & UTIL BAR ==================== */
    .top-promo {
      background: var(--green-dark); color: white; text-align: center;
      padding: 0.6rem 1rem; font-size: 0.82rem; font-weight: 500;
    }
    .top-promo a { color: var(--gold-light); font-weight: 700; margin-left: 0.5rem; }

    .utility-bar {
      background: var(--bg-offwhite); border-bottom: 1px solid var(--border);
      padding: 0.5rem 0; font-size: 0.78rem;
    }
    .utility-inner {
      display: flex; justify-content: space-between; align-items: center;
      flex-wrap: wrap; gap: 0.5rem;
    }
    .util-tabs { display: flex; gap: 1.5rem; }
    .util-tabs a { color: var(--text-muted); font-weight: 600; }
    .util-tabs a:hover { color: var(--navy); }
    .util-tabs a.active { color: var(--green-main); border-bottom: 2px solid var(--green-main); padding-bottom: 1px; pointer-events: none; }
    .util-auth a { color: var(--green-main); font-weight: 700; margin-left: 1rem; }
    .util-auth a:hover { color: var(--navy); }

    /* ==================== NAVIGATION ==================== */
    .top-nav {
      background: rgba(255,255,255,0.95); backdrop-filter: blur(12px);
      border-bottom: 1px solid var(--border); position: sticky; top: 0; z-index: 100;
    }
    .nav-inner {
      display: flex; align-items: center; justify-content: space-between;
      height: 70px;
    }
    .logo { font-family: 'DM Serif Display', serif; font-size: 1.4rem; color: var(--navy); }
    .logo span { color: var(--gold); }
    .main-nav { display: flex; align-items: center; gap: 0.25rem; }
    .nav-link {
      padding: 0.5rem 0.85rem; font-size: 0.88rem; font-weight: 600;
      color: var(--text-secondary); border-radius: var(--radius-sm);
    }
    .nav-link:hover { background: var(--bg-offwhite); color: var(--green-main); }
    .nav-actions { display: flex; align-items: center; gap: 0.75rem; }
    .hamburger { display: none; background: none; border: none; font-size: 1.5rem; cursor: pointer; padding: 0.25rem; }

    /* ==================== HERO ==================== */
    .hero {
      background: linear-gradient(165deg, var(--navy) 0%, var(--green-dark) 40%, var(--green-main) 100%);
      color: white; padding: 5rem 0 4.5rem; position: relative; overflow: hidden;
    }
    .hero::before {
      content: ''; position: absolute; inset: 0;
      background: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='0.02'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
      pointer-events: none;
    }
    .hero-inner {
      display: grid; grid-template-columns: 1.1fr 0.9fr; gap: 4rem; align-items: center;
      position: relative; z-index: 2;
    }
    .hero-label {
      display: inline-flex; align-items: center; gap: 0.5rem;
      background: rgba(200,160,69,0.15); border: 1px solid rgba(200,160,69,0.3);
      padding: 0.35rem 1rem; border-radius: 50px; font-size: 0.7rem;
      font-weight: 700; text-transform: uppercase; letter-spacing: 1.5px;
      color: var(--gold-light); margin-bottom: 1.5rem;
    }
    .hero-title {
      font-family: 'DM Serif Display', serif;
      font-size: clamp(2.4rem, 4.5vw, 3.5rem); line-height: 1.15;
      margin-bottom: 1.25rem; font-weight: 400;
    }
    .hero-title .highlight { color: var(--gold-light); }
    .hero-sub {
      font-size: 1.1rem; color: rgba(255,255,255,0.75); margin-bottom: 2rem;
      max-width: 520px; line-height: 1.7;
    }
    .hero-actions { display: flex; gap: 1rem; flex-wrap: wrap; margin-bottom: 2.5rem; }
    .hero-meta {
      display: flex; flex-wrap: wrap; gap: 1.5rem;
      font-size: 0.8rem; color: rgba(255,255,255,0.5);
    }
    .hero-meta span { display: flex; align-items: center; gap: 0.4rem; }

    .hero-visual { position: relative; height: 400px; }
    .float-card {
      background: rgba(255,255,255,0.08); backdrop-filter: blur(16px);
      border: 1px solid rgba(255,255,255,0.12); border-radius: var(--radius-lg);
      padding: 1.5rem; color: white; position: absolute;
      box-shadow: 0 20px 50px rgba(0,0,0,0.25);
      animation: float 6s ease-in-out infinite;
    }
    .fc-balance { width: 310px; top: 30px; left: 0; z-index: 2; }
    .fc-rate { width: 230px; bottom: 60px; right: 0; z-index: 1; border-color: rgba(200,160,69,0.35); background: rgba(200,160,69,0.1); animation-delay: -2s; }
    .fc-label { font-size: 0.68rem; text-transform: uppercase; letter-spacing: 1.5px; opacity: 0.7; margin-bottom: 0.4rem; }
    .fc-val { font-family: 'DM Serif Display', serif; font-size: 1.9rem; font-weight: 700; }
    .fc-badge { background: var(--gold); color: var(--navy); padding: 3px 10px; border-radius: 20px; font-size: 0.65rem; font-weight: 700; display: inline-block; margin-top: 0.5rem; }
    @keyframes float { 0%, 100% { transform: translateY(0); } 50% { transform: translateY(-10px); } }

    /* ==================== STATS ==================== */
    .stats-bar {
      background: var(--bg-white); border-bottom: 1px solid var(--border);
      padding: 2.5rem 0; position: relative; z-index: 10;
    }
    .stats-grid {
      display: grid; grid-template-columns: repeat(4, 1fr); gap: 2rem; text-align: center;
    }
    .stat-num { font-family: 'DM Serif Display', serif; font-size: 1.9rem; color: var(--green-main); font-weight: 700; }
    .stat-desc { font-size: 0.75rem; color: var(--text-muted); margin-top: 0.25rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.5px; }

    /* ==================== QUICK ACTIONS ==================== */
    .quick-strip { margin-top: -40px; position: relative; z-index: 10; padding: 0 1rem; }
    .quick-box {
      background: var(--bg-white); border-radius: var(--radius-lg);
      box-shadow: var(--shadow-lg); padding: 2rem;
      display: flex; justify-content: space-around; flex-wrap: wrap; gap: 1.5rem;
    }
    .q-item {
      text-align: center; padding: 0.75rem; border-radius: var(--radius-sm);
      min-width: 110px; transition: var(--transition);
    }
    .q-item:hover { background: var(--bg-offwhite); transform: translateY(-3px); }
    .q-icon {
      width: 46px; height: 46px; margin: 0 auto 0.5rem;
      background: #ecfdf5; border-radius: 50%;
      display: flex; align-items: center; justify-content: center;
      font-size: 1.25rem; color: var(--green-main);
    }
    .q-text { font-weight: 700; font-size: 0.82rem; color: var(--navy); }

    /* ==================== PRODUCT CARDS ==================== */
    .prod-grid {
      display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 1.5rem;
    }
    .prod-card {
      background: var(--bg-white); border: 1px solid var(--border);
      border-radius: var(--radius-md); overflow: hidden; transition: var(--transition);
    }
    .prod-card:hover { border-color: var(--gold); box-shadow: var(--shadow-md); transform: translateY(-4px); }
    .prod-icon-area {
      height: 140px; background: linear-gradient(135deg, #ecfdf5, #e2e8f0);
      display: flex; align-items: center; justify-content: center;
      font-size: 3.2rem; color: var(--green-main);
    }
    .prod-body { padding: 1.5rem; }
    .prod-tag { display: inline-block; font-size: 0.65rem; font-weight: 700; text-transform: uppercase; letter-spacing: 1px; color: var(--gold); margin-bottom: 0.4rem; }
    .prod-body h3 { font-family: 'DM Serif Display', serif; font-size: 1.15rem; margin-bottom: 0.5rem; color: var(--navy); }
    .prod-body p { font-size: 0.88rem; color: var(--text-secondary); line-height: 1.6; margin-bottom: 1.25rem; }
    .prod-link { display: inline-flex; align-items: center; gap: 0.4rem; font-size: 0.85rem; font-weight: 700; color: var(--green-main); }
    .prod-link:hover { gap: 0.7rem; }

    /* ==================== TRUST / FEATURES ==================== */
    .trust-section { background: var(--bg-offwhite); }
    .trust-grid {
      display: grid; grid-template-columns: repeat(auto-fit, minmax(230px, 1fr)); gap: 1.5rem;
    }
    .trust-card {
      background: var(--bg-white); border-radius: var(--radius-md);
      padding: 2rem; text-align: center; border: 1px solid var(--border);
      transition: var(--transition);
    }
    .trust-card:hover { box-shadow: var(--shadow-sm); transform: translateY(-3px); }
    .trust-icon { font-size: 2.2rem; margin-bottom: 0.75rem; }
    .trust-card h4 { font-size: 0.95rem; margin-bottom: 0.35rem; color: var(--navy); }
    .trust-card p { font-size: 0.85rem; color: var(--text-secondary); }

    /* ==================== TESTIMONIALS ==================== */
    .testi-grid {
      display: grid; grid-template-columns: repeat(auto-fit, minmax(320px, 1fr)); gap: 1.5rem;
    }
    .testi-card {
      background: var(--bg-white); border: 1px solid var(--border);
      border-radius: var(--radius-md); padding: 2rem; transition: var(--transition);
    }
    .testi-card:hover { box-shadow: var(--shadow-sm); }
    .stars { color: var(--gold); font-size: 0.9rem; margin-bottom: 1rem; letter-spacing: 2px; }
    .testi-quote { font-size: 0.92rem; color: var(--text-secondary); font-style: italic; line-height: 1.7; margin-bottom: 1.25rem; }
    .testi-author { display: flex; align-items: center; gap: 0.75rem; }
    .testi-avatar { width: 42px; height: 42px; border-radius: 50%; background: #ecfdf5; display: flex; align-items: center; justify-content: center; font-size: 1.1rem; }
    .testi-name { font-size: 0.85rem; font-weight: 700; color: var(--navy); }
    .testi-role { font-size: 0.72rem; color: var(--text-muted); }

    /* ==================== APP PROMO ==================== */
    .app-section { background: var(--navy); color: white; padding: 5.5rem 0; }
    .app-grid {
      display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; align-items: center;
    }
    .app-text h2 { font-family: 'DM Serif Display', serif; font-size: clamp(1.8rem, 3vw, 2.4rem); margin-bottom: 1rem; }
    .app-text p { color: rgba(255,255,255,0.7); margin-bottom: 2rem; font-size: 1.05rem; line-height: 1.7; }
    .app-list { display: flex; flex-direction: column; gap: 0.75rem; margin-bottom: 2rem; }
    .app-item { display: flex; align-items: center; gap: 0.75rem; font-weight: 500; }
    .app-check { color: var(--gold); font-weight: 900; font-size: 1.1rem; }
    .phone-mockup {
      background: linear-gradient(145deg, #1a5c30, #2ea55a);
      border-radius: 28px; height: 400px;
      display: flex; align-items: center; justify-content: center;
      font-size: 4.5rem; box-shadow: 0 25px 60px rgba(0,0,0,0.35);
    }

    /* ==================== RESOURCES ==================== */
    .resource-grid {
      display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 1rem;
    }
    .res-card {
      background: var(--bg-white); border: 1px solid var(--border);
      border-radius: var(--radius-md); padding: 1.5rem;
      transition: var(--transition); display: block;
    }
    .res-card:hover { border-color: var(--green-main); box-shadow: var(--shadow-sm); transform: translateY(-2px); }
    .res-icon { font-size: 2rem; margin-bottom: 0.5rem; }
    .res-card h4 { font-size: 0.95rem; margin-bottom: 0.25rem; color: var(--navy); }
    .res-card p { font-size: 0.82rem; color: var(--text-secondary); }

    /* ==================== CTA ==================== */
    .cta-banner {
      background: linear-gradient(135deg, var(--gold), #b8862d);
      text-align: center; padding: 5rem 1.5rem; position: relative; overflow: hidden;
    }
    .cta-banner::before {
      content: ''; position: absolute; inset: 0;
      background: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='0.08'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
    }
    .cta-inner { position: relative; z-index: 2; max-width: 650px; margin: 0 auto; }
    .cta-banner h2 { font-family: 'DM Serif Display', serif; font-size: clamp(1.8rem, 3vw, 2.4rem); color: var(--navy); margin-bottom: 0.75rem; }
    .cta-banner p { color: #78350f; font-size: 1.05rem; margin-bottom: 2rem; line-height: 1.7; }

    /* ==================== FOOTER ==================== */
    .site-footer {
      background: var(--navy); color: rgba(255,255,255,0.6); padding: 3.5rem 0 1.5rem;
      font-size: 0.85rem;
    }
    .footer-inner {
      display: grid; grid-template-columns: 1.5fr 1fr 1fr 1fr; gap: 2.5rem;
      padding-bottom: 2.5rem; border-bottom: 1px solid rgba(255,255,255,0.08);
    }
    .footer-brand { font-family: 'DM Serif Display', serif; font-size: 1.35rem; color: white; margin-bottom: 0.75rem; }
    .footer-brand span { color: var(--gold); }
    .footer-desc { font-size: 0.85rem; line-height: 1.7; max-width: 300px; }
    .footer-col h5 {
      font-size: 0.7rem; text-transform: uppercase; letter-spacing: 1.5px;
      color: rgba(255,255,255,0.9); font-weight: 700; margin-bottom: 1rem;
    }
    .footer-col ul li { margin-bottom: 0.5rem; }
    .footer-col ul li a:hover { color: var(--gold); }
    .footer-bottom {
      padding-top: 1.5rem; text-align: center; font-size: 0.75rem; color: rgba(255,255,255,0.4);
    }

    /* ==================== MOBILE MENU ==================== */
    .mobile-overlay {
      display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.45);
      z-index: 99; opacity: 0; transition: opacity 0.3s;
    }
    .mobile-overlay.show { display: block; opacity: 1; }
    .mobile-sheet {
      position: fixed; top: 0; left: 0; bottom: 0; width: 280px;
      background: var(--bg-white); z-index: 101; padding: 1.5rem;
      overflow-y: auto; transform: translateX(-100%); transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1);
      box-shadow: 4px 0 20px rgba(0,0,0,0.1);
    }
    .mobile-sheet.open { transform: translateX(0); }
    .mobile-close { background: none; border: none; font-size: 1.5rem; cursor: pointer; padding: 0.5rem 0; margin-bottom: 1.5rem; }
    .mob-links { display: flex; flex-direction: column; gap: 0.25rem; margin-bottom: 1.5rem; }
    .mob-link { padding: 0.75rem 0.5rem; border-radius: var(--radius-sm); font-weight: 600; font-size: 0.95rem; }
    .mob-link:hover { background: var(--bg-offwhite); }
    .mob-actions { display: flex; flex-direction: column; gap: 0.75rem; }

    /* ==================== ANIMATIONS ==================== */
    @keyframes fadeUp { from { opacity: 0; transform: translateY(16px); } to { opacity: 1; transform: translateY(0); } }
    .fade-up { animation: fadeUp 0.6s cubic-bezier(0.16, 1, 0.3, 1) both; }
    .delay-1 { animation-delay: 0.1s; }
    .delay-2 { animation-delay: 0.2s; }
    .delay-3 { animation-delay: 0.3s; }
    .delay-4 { animation-delay: 0.4s; }

    /* ==================== RESPONSIVE ==================== */
    @media (max-width: 1024px) {
      .hero-inner { grid-template-columns: 1fr; }
      .hero-visual { display: none; }
      .hero-sub { margin: 0 auto 2rem; }
      .hero-actions { justify-content: center; }
      .hero-meta { justify-content: center; }
      .stats-grid { grid-template-columns: repeat(2, 1fr); gap: 1.5rem; }
      .app-grid { grid-template-columns: 1fr; text-align: center; }
      .app-list { align-items: center; }
      .phone-mockup { height: 300px; margin: 0 auto; }
      .footer-inner { grid-template-columns: 1fr 1fr; }
    }

    @media (max-width: 768px) {
      .section { padding: 3.5rem 0; }
      .utility-inner { flex-direction: column; align-items: flex-start; gap: 0.5rem; }
      .util-tabs { gap: 1rem; }
      .util-auth { margin-left: 0; }
      .nav-inner { padding: 0 1rem; }
      .main-nav { display: none; }
      .hamburger { display: block; }
      .nav-actions { display: none; }
      .quick-box { padding: 1.5rem; gap: 1rem; }
      .prod-grid { grid-template-columns: 1fr; }
      .testi-grid { grid-template-columns: 1fr; }
      .trust-grid { grid-template-columns: 1fr; }
      .resource-grid { grid-template-columns: 1fr; }
      .footer-inner { grid-template-columns: 1fr; gap: 2rem; }
      .cta-banner { padding: 3.5rem 1.5rem; }
    }

    @media (max-width: 480px) {
      .hero { padding: 3.5rem 0 3rem; }
      .hero-title { font-size: 2rem; }
      .hero-actions { flex-direction: column; width: 100%; }
      .hero-actions .btn { width: 100%; justify-content: center; }
      .stats-grid { grid-template-columns: 1fr 1fr; gap: 1rem; }
      .stat-num { font-size: 1.5rem; }
      .quick-strip { margin-top: -25px; }
      .quick-box { gap: 0.75rem; padding: 1.25rem; }
      .q-item { min-width: 80px; }
      .q-text { font-size: 0.75rem; }
    }
  </style>
</head>
<body>

  <!-- TOP PROMO -->
  <div class="top-promo">
    🌱 New Customers: Earn a $500 bonus when you open an AgriBusiness Checking account.
    <a href="/promo-checking">Learn More →</a>
  </div>

  <!-- UTILITY BAR -->
  <div class="utility-bar">
    <div class="container utility-inner">
      <div class="util-tabs">
        <a href="/" class="active">Personal</a>
        <a href="/small-business">Small Business</a>
        <a href="/commercial-farming">Commercial Farming</a>
      </div>
      <div class="util-auth">
        <% if (typeof user !== 'undefined' && user) { %>
          <a href="/dashboard">Dashboard</a>
          <a href="/logout">Sign Out</a>
        <% } else { %>
          <a href="/login">Secure Login</a>
          <a href="/register">Open Account</a>
        <% } %>
      </div>
    </div>
  </div>

  <!-- MAIN NAVIGATION -->
  <nav class="top-nav">
    <div class="container nav-inner">
      <div style="display:flex; align-items:center; gap:1rem;">
        <button class="hamburger" id="menuToggle">☰</button>
        <a href="/" class="logo">Agri<span>Bank</span></a>
      </div>
      <div class="main-nav">
